<Window x:Class="食品信息管理系统.Views.Dialogs.CustomerInfoEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="客户信息编辑" Height="650" Width="920"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="90"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="客户编号:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="CustomerIdText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="来源:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <ComboBox Grid.Row="0" Grid.Column="3" x:Name="SourceCombo" IsEditable="True" IsTextSearchEnabled="True"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="客户名称:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="CustomerNameText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="客户类型:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <ComboBox Grid.Row="1" Grid.Column="3" x:Name="CustomerTypeCombo" IsEditable="True" IsTextSearchEnabled="True"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="许可证号:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="LicenseNoText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="2" Text="许可证有效期:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="2" Grid.Column="3" x:Name="LicenseValidityText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="营业执照:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="BusinessLicenseText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="3" Grid.Column="2" Text="营业有效期:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="3" Grid.Column="3" x:Name="BusinessValidityText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="联系地址:" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,6,8,0"/>
                <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" x:Name="ContactAddressText" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="邮政编码:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="5" Grid.Column="1" x:Name="PostalCodeText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="5" Grid.Column="2" Text="联系人:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="5" Grid.Column="3" x:Name="ContactPersonText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="联系电话:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="6" Grid.Column="1" x:Name="ContactPhoneText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="6" Grid.Column="2" Text="启用状态:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <CheckBox Grid.Row="6" Grid.Column="3" x:Name="IsDisabledCheck" Content="停用" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="备注:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="3" x:Name="RemarkText" VerticalContentAlignment="Center"/>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="保存" Width="88" Margin="0,0,8,0" Click="SaveButton_Click"/>
            <Button Content="取消" Width="88" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
