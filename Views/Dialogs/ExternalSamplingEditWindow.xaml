<Window x:Class="食品信息管理系统.Views.Dialogs.ExternalSamplingEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="外部抽检编辑" Height="430" Width="700"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="90"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="抽检编号:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="SamplingIdText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="0" Grid.Column="2" Text="抽检日期:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <DatePicker Grid.Row="0" Grid.Column="3" x:Name="SamplingDatePicker" SelectedDateFormat="Short"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="产品编码:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="ProductIdText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="1" Grid.Column="2" Text="批号:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="1" Grid.Column="3" x:Name="BatchNoText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="产品数量:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="ProductQuantityText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="2" Grid.Column="2" Text="抽样数量:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="2" Grid.Column="3" x:Name="SamplingQuantityText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="抽样价格:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="3" Grid.Column="1" x:Name="SamplingPriceText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="3" Grid.Column="2" Text="监测类型:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <ComboBox Grid.Row="3" Grid.Column="3" x:Name="MonitorTypeCombo" IsEditable="True" IsTextSearchEnabled="True"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="抽检机构:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <ComboBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" x:Name="SamplingOrgCombo" IsEditable="True" IsTextSearchEnabled="True"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="备注:" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,6,8,0"/>
            <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" x:Name="RemarkText" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="保存" Width="88" Margin="0,0,8,0" Click="SaveButton_Click"/>
            <Button Content="取消" Width="88" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
