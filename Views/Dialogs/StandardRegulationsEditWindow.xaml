<Window x:Class="食品信息管理系统.Views.Dialogs.StandardRegulationsEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="标准规范编辑" Height="760" Width="960"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="90"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="标准编号:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="StandardIdText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="节点编码:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="0" Grid.Column="3" x:Name="NodeCodeText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="分类:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="CategoryCombo" IsEditable="True" IsTextSearchEnabled="True"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="系列:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <ComboBox Grid.Row="1" Grid.Column="3" x:Name="SeriesCombo" IsEditable="True" IsTextSearchEnabled="True"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="标准名称:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="StandardNameText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="2" Text="标准代号:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="2" Grid.Column="3" x:Name="StandardCodeText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="发布部门:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="PublishDeptText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="3" Grid.Column="2" Text="发布年份:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="3" Grid.Column="3" x:Name="PublishYearText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="发布日期:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <DatePicker Grid.Row="4" Grid.Column="1" x:Name="PublishDatePicker" SelectedDateFormat="Short"/>

                <TextBlock Grid.Row="4" Grid.Column="2" Text="实施日期:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <DatePicker Grid.Row="4" Grid.Column="3" x:Name="ImplementDatePicker" SelectedDateFormat="Short"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="修订日期:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <DatePicker Grid.Row="5" Grid.Column="1" x:Name="RevisionDatePicker" SelectedDateFormat="Short"/>

                <TextBlock Grid.Row="5" Grid.Column="2" Text="生效日期:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <DatePicker Grid.Row="5" Grid.Column="3" x:Name="EffectiveDatePicker" SelectedDateFormat="Short"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="HACCP适用:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <CheckBox Grid.Row="6" Grid.Column="1" x:Name="AppliesToHaccpCheck" Content="适用" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="6" Grid.Column="2" Text="失效状态:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <CheckBox Grid.Row="6" Grid.Column="3" x:Name="IsInvalidCheck" Content="失效" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="标准链接:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="3" x:Name="StandardLinkText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="新标准链接:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="3" x:Name="NewStandardLinkText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="9" Grid.Column="0" Text="排序:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="9" Grid.Column="1" x:Name="SortOrderText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="9" Grid.Column="2" Text="启用状态:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <CheckBox Grid.Row="9" Grid.Column="3" x:Name="IsEnabledCheck" Content="启用" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="10" Grid.Column="0" Text="备注:" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,6,8,0"/>
                <TextBox Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="3" x:Name="RemarkText" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="保存" Width="88" Margin="0,0,8,0" Click="SaveButton_Click"/>
            <Button Content="取消" Width="88" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
