<Window x:Class="食品信息管理系统.Views.Dialogs.ExamConfigEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="考试配置编辑" Height="760" Width="980"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="90"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="配置编号:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="ConfigIdText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="节点编码:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="0" Grid.Column="3" x:Name="NodeCodeText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="考试名称:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="ExamNameText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="考试类型:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <ComboBox Grid.Row="1" Grid.Column="3" x:Name="ExamTypeCombo" IsEditable="True" IsTextSearchEnabled="True"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="部门:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="DepartmentText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="2" Text="总分:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="2" Grid.Column="3" x:Name="TotalScoreText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="及格分:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="PassScoreText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="3" Grid.Column="2" Text="时长(分):" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="3" Grid.Column="3" x:Name="DurationMinutesText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="判断题数:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="4" Grid.Column="1" x:Name="JudgeCountText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="4" Grid.Column="2" Text="判断单分:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="4" Grid.Column="3" x:Name="JudgeSingleScoreText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="单选题数:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="5" Grid.Column="1" x:Name="SingleCountText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="5" Grid.Column="2" Text="单选单分:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="5" Grid.Column="3" x:Name="SingleSingleScoreText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="多选题数:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="6" Grid.Column="1" x:Name="MultiCountText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="6" Grid.Column="2" Text="多选单分:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="6" Grid.Column="3" x:Name="MultiSingleScoreText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="简答题数:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="7" Grid.Column="1" x:Name="EssayCountText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="7" Grid.Column="2" Text="简答单分:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="7" Grid.Column="3" x:Name="EssaySingleScoreText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="分类筛选:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="8" Grid.Column="1" x:Name="CategoryFilterText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="8" Grid.Column="2" Text="难度筛选:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="8" Grid.Column="3" x:Name="DifficultyFilterText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="9" Grid.Column="0" Text="创建人:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="9" Grid.Column="1" x:Name="CreatedByText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="9" Grid.Column="2" Text="停用:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <CheckBox Grid.Row="9" Grid.Column="3" x:Name="IsEnabledCheck" Content="启用" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="10" Grid.Column="0" Text="备注:" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,6,8,0"/>
                <TextBox Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="3" x:Name="RemarkText" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="保存" Width="88" Margin="0,0,8,0" Click="SaveButton_Click"/>
            <Button Content="取消" Width="88" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
