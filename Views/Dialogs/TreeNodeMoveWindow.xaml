<Window x:Class="食品信息管理系统.Views.Dialogs.TreeNodeMoveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="移动节点" Height="420" Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="8"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <GroupBox Header="选择父节点" Grid.Column="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TreeView x:Name="ParentTreeView"
                          Margin="6"
                          SelectedItemChanged="ParentTreeView_SelectedItemChanged"/>
                <TextBlock Grid.Row="1" Margin="8,0,8,8" Foreground="#666666"
                           Text="选择根节点表示移动到顶级；不可选当前节点及其子孙节点。"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Column="2" Margin="8,0,0,0">
            <GroupBox Header="当前节点" Margin="0,0,0,10">
                <StackPanel Margin="8">
                    <TextBlock Text="标题" FontWeight="Bold"/>
                    <TextBlock x:Name="CurrentTitleText" Margin="0,4,0,8" TextWrapping="Wrap"/>
                    <TextBlock Text="编码" FontWeight="Bold"/>
                    <TextBlock x:Name="CurrentCodeText" Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="移动设置" Margin="0,0,0,10">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="92"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="同级位置：" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TargetIndexText"
                             Height="26" VerticalContentAlignment="Center"
                             PreviewTextInput="TargetIndexText_PreviewTextInput"/>

                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="PositionHintText"
                               Margin="0,6,0,6" Foreground="#666666" TextWrapping="Wrap"/>

                    <CheckBox Grid.Row="2" Grid.Column="1" x:Name="RegenerateCodesCheckBox"
                              Content="重生成编码" IsChecked="True" Margin="0,4,0,0"/>
                </Grid>
            </GroupBox>

            <TextBlock x:Name="SelectionHintText" Margin="2,0,2,10" Foreground="#666666"
                       TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="确定" Width="72" Height="28" Margin="0,0,8,0" IsDefault="True" Click="OkButton_Click"/>
                <Button Content="取消" Width="72" Height="28" IsCancel="True" Click="CancelButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>