<Window x:Class="食品信息管理系统.Views.Dialogs.CommissionedOrderEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="委托订单编辑" Height="560" Width="860"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="90"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="订单编号:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="OrderIdText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="0" Grid.Column="2" Text="订单日期:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <DatePicker Grid.Row="0" Grid.Column="3" x:Name="OrderDatePicker" SelectedDateFormat="Short"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="客户名称:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="CustomerNameText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="1" Grid.Column="2" Text="联系人:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="1" Grid.Column="3" x:Name="ContactPersonText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="联系电话:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="ContactPhoneText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="2" Grid.Column="2" Text="产品名称:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="2" Grid.Column="3" x:Name="ProductNameText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="产品规格:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="3" Grid.Column="1" x:Name="ProductSpecText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="3" Grid.Column="2" Text="订单数量:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="3" Grid.Column="3" x:Name="OrderQuantityText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="订单类型:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <ComboBox Grid.Row="4" Grid.Column="1" x:Name="OrderTypeCombo" IsEditable="True" IsTextSearchEnabled="True"/>

            <TextBlock Grid.Row="4" Grid.Column="2" Text="检验标准:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="4" Grid.Column="3" x:Name="InspectionStandardText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="要求日期:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <DatePicker Grid.Row="5" Grid.Column="1" x:Name="RequiredDatePicker" SelectedDateFormat="Short"/>

            <TextBlock Grid.Row="5" Grid.Column="2" Text="实际日期:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <DatePicker Grid.Row="5" Grid.Column="3" x:Name="ActualDatePicker" SelectedDateFormat="Short"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="订单状态:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <ComboBox Grid.Row="6" Grid.Column="1" x:Name="OrderStatusCombo" IsEditable="True" IsTextSearchEnabled="True"/>

            <TextBlock Grid.Row="6" Grid.Column="2" Text="付款状态:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <ComboBox Grid.Row="6" Grid.Column="3" x:Name="PaymentStatusCombo" IsEditable="True" IsTextSearchEnabled="True"/>

            <TextBlock Grid.Row="7" Grid.Column="0" Text="检验费用:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="7" Grid.Column="1" x:Name="InspectionFeeText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="7" Grid.Column="2" Text="检验项目:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="7" Grid.Column="3" x:Name="InspectionItemsText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="8" Grid.Column="0" Text="备注:" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,6,8,0"/>
            <TextBox Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="3" x:Name="RemarkText" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="保存" Width="88" Margin="0,0,8,0" Click="SaveButton_Click"/>
            <Button Content="取消" Width="88" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
