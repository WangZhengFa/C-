<Window x:Class="食品信息管理系统.Views.Dialogs.CommonDictFieldDefsEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="字段定义编辑" Height="660" Width="900"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="90"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="字段键:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="FieldKeyText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="字段标签:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="0" Grid.Column="3" x:Name="FieldLabelText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="字段类型:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <ComboBox Grid.Row="1" Grid.Column="1" x:Name="FieldTypeCombo" IsEditable="True" IsTextSearchEnabled="True"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="节点编码:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="1" Grid.Column="3" x:Name="NodeCodeText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="占位提示:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="PlaceholderText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="2" Text="排序:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="2" Grid.Column="3" x:Name="SortOrderText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="最小值:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="MinValueText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="3" Grid.Column="2" Text="最大值:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="3" Grid.Column="3" x:Name="MaxValueText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="选项:" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,6,8,0"/>
                <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" x:Name="OptionsText" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="描述:" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,6,8,0"/>
                <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" x:Name="DescriptionText" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="启用状态:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <CheckBox Grid.Row="6" Grid.Column="1" x:Name="IsEnabledCheck" Content="启用" VerticalAlignment="Center"/>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="保存" Width="88" Margin="0,0,8,0" Click="SaveButton_Click"/>
            <Button Content="取消" Width="88" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
