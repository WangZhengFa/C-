<Window x:Class="食品信息管理系统.Views.Dialogs.MaterialInfoEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="物料信息编辑" Height="520" Width="860"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="90"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="物料ID:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="MaterialIdText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="0" Grid.Column="2" Text="节点编码:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="0" Grid.Column="3" x:Name="NodeCodeText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="一级编码:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="FirstLevelCodeText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="1" Grid.Column="2" Text="物料编码:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="1" Grid.Column="3" x:Name="MaterialCodeText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="物料名称:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="MaterialNameText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="2" Grid.Column="2" Text="规格:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="2" Grid.Column="3" x:Name="SpecificationText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="包装规格:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="3" Grid.Column="1" x:Name="PackagingSpecText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="3" Grid.Column="2" Text="品牌系列:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <ComboBox Grid.Row="3" Grid.Column="3" x:Name="BrandSeriesCombo" IsEditable="True" IsTextSearchEnabled="True"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="有效期(天):" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="4" Grid.Column="1" x:Name="ExpiryDateText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="4" Grid.Column="2" Text="单位:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <ComboBox Grid.Row="4" Grid.Column="3" x:Name="UnitCombo" IsEditable="True" IsTextSearchEnabled="True"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="标准:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="5" Grid.Column="1" x:Name="StandardText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="5" Grid.Column="2" Text="停用状态:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <CheckBox Grid.Row="5" Grid.Column="3" x:Name="IsDisabledCheck" Content="已停用" VerticalAlignment="Center"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="备注:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3" x:Name="RemarkText" VerticalContentAlignment="Center"/>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="保存" Width="88" Margin="0,0,8,0" Click="SaveButton_Click"/>
            <Button Content="取消" Width="88" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
