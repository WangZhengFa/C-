<Window x:Class="食品信息管理系统.Views.Dialogs.ReportIssuanceEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="报告发放编辑" Height="430" Width="620"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="90"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="报告编号:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="ReportCodeText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="0" Grid.Column="2" Text="发放日期:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <DatePicker Grid.Row="0" Grid.Column="3" x:Name="DistributionDatePicker" SelectedDateFormat="Short"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="发放人:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <ComboBox Grid.Row="1" Grid.Column="1" x:Name="DistributorCombo" IsEditable="True" IsTextSearchEnabled="True"/>

            <TextBlock Grid.Row="1" Grid.Column="2" Text="接收人:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <ComboBox Grid.Row="1" Grid.Column="3" x:Name="RecipientCombo" IsEditable="True" IsTextSearchEnabled="True"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="接收日期:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <DatePicker Grid.Row="2" Grid.Column="1" x:Name="ReceiveDatePicker" SelectedDateFormat="Short"/>

            <TextBlock Grid.Row="2" Grid.Column="2" Text="签收人:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <ComboBox Grid.Row="2" Grid.Column="3" x:Name="AcceptorCombo" IsEditable="True" IsTextSearchEnabled="True"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="已接收:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <CheckBox Grid.Row="3" Grid.Column="1" x:Name="IsReceivedCheck" VerticalAlignment="Center"/>

            <TextBlock Grid.Row="3" Grid.Column="2" Text="已签收:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <CheckBox Grid.Row="3" Grid.Column="3" x:Name="IsAcceptedCheck" VerticalAlignment="Center"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="签收日期:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <DatePicker Grid.Row="4" Grid.Column="1" x:Name="AcceptDatePicker" SelectedDateFormat="Short"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="备注:" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,6,8,0"/>
            <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" x:Name="RemarkText" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="保存" Width="88" Margin="0,0,8,0" Click="SaveButton_Click"/>
            <Button Content="取消" Width="88" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
