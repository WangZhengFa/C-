<Window x:Class="食品信息管理系统.Views.Dialogs.ExamQuestionBankEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="考试题库编辑" Height="640" Width="900"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="90"/>
                    <RowDefinition Height="90"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="90"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="题型:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <ComboBox Grid.Row="0" Grid.Column="1" x:Name="QuestionTypeCombo" IsEditable="True" IsTextSearchEnabled="True"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="分类:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="0" Grid.Column="3" x:Name="CategoryText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="题目内容:" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,6,8,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" x:Name="QuestionContentText" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="选项JSON:" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,6,8,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" x:Name="OptionsJsonText" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="答案:" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,6,8,0"/>
                <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" x:Name="AnswerText" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="解析:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="3" x:Name="AnalysisText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="难度:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <ComboBox Grid.Row="5" Grid.Column="1" x:Name="DifficultyCombo" IsEditable="True" IsTextSearchEnabled="True"/>

                <TextBlock Grid.Row="5" Grid.Column="2" Text="启用状态:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <CheckBox Grid.Row="5" Grid.Column="3" x:Name="IsEnabledCheck" Content="启用" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="备注:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3" x:Name="RemarkText" VerticalContentAlignment="Center"/>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="保存" Width="88" Margin="0,0,8,0" Click="SaveButton_Click"/>
            <Button Content="取消" Width="88" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
