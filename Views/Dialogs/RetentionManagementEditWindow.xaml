<Window x:Class="食品信息管理系统.Views.Dialogs.RetentionManagementEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="留样管理编辑" Height="520" Width="800"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="90"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="留样编号:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="RetentionCodeText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="0" Grid.Column="2" Text="报告编号:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="0" Grid.Column="3" x:Name="ReportCodeText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="物料编码:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="MaterialIdText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="1" Grid.Column="2" Text="批号:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="1" Grid.Column="3" x:Name="BatchNumberText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="留样日期:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <DatePicker Grid.Row="2" Grid.Column="1" x:Name="RetentionDatePicker" SelectedDateFormat="Short"/>

            <TextBlock Grid.Row="2" Grid.Column="2" Text="留样人:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="2" Grid.Column="3" x:Name="RetentionPersonText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="截止日期:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <DatePicker Grid.Row="3" Grid.Column="1" x:Name="RetentionDeadlinePicker" SelectedDateFormat="Short"/>

            <TextBlock Grid.Row="3" Grid.Column="2" Text="留样地点:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="3" Grid.Column="3" x:Name="RetentionLocationText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="留样数量:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="4" Grid.Column="1" x:Name="RetentionQuantityText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="4" Grid.Column="2" Text="存储条件:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="4" Grid.Column="3" x:Name="StorageConditionText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="样品状态:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <ComboBox Grid.Row="5" Grid.Column="1" x:Name="SampleStatusCombo" IsEditable="True" IsTextSearchEnabled="True"/>

            <TextBlock Grid.Row="5" Grid.Column="2" Text="处置日期:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <DatePicker Grid.Row="5" Grid.Column="3" x:Name="DisposeDatePicker" SelectedDateFormat="Short"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="处置人:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="6" Grid.Column="1" x:Name="DisposePersonText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="7" Grid.Column="0" Text="备注:" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,6,8,0"/>
            <TextBox Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="3" x:Name="RemarkText" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="保存" Width="88" Margin="0,0,8,0" Click="SaveButton_Click"/>
            <Button Content="取消" Width="88" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
