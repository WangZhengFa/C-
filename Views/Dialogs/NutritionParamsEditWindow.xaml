<Window x:Class="食品信息管理系统.Views.Dialogs.NutritionParamsEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="营养参数编辑" Height="820" Width="980"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="90"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="90"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="排序:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="SortOrderText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="营养素:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="0" Grid.Column="3" x:Name="NutrientText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="单位:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="UnitText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="四舍五入间隔:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="1" Grid.Column="3" x:Name="RoundingIntervalText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="零值阈值:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="ZeroThresholdText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="2" Text="能量值:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="2" Grid.Column="3" x:Name="EnergyValueText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="下限误差:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="LowerErrorText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="3" Grid.Column="2" Text="上限误差:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="3" Grid.Column="3" x:Name="UpperErrorText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="NRV:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="4" Grid.Column="1" x:Name="NrvText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="4" Grid.Column="2" Text="日摄入范围:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="4" Grid.Column="3" x:Name="DailyUsageRangeText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="核心:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <CheckBox Grid.Row="6" Grid.Column="1" x:Name="CoreCheck" Content="核心" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="6" Grid.Column="2" Text="重金属:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <CheckBox Grid.Row="6" Grid.Column="3" x:Name="HeavyMetalCheck" Content="重金属" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="运动营养:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <CheckBox Grid.Row="7" Grid.Column="1" x:Name="IsSportsNutritionCheck" Content="运动营养" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="7" Grid.Column="2" Text="停用:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <CheckBox Grid.Row="7" Grid.Column="3" x:Name="DisabledCheck" Content="停用" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="描述:" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,6,8,0"/>
                <TextBox Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="3" x:Name="DescriptionText" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="保存" Width="88" Margin="0,0,8,0" Click="SaveButton_Click"/>
            <Button Content="取消" Width="88" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
