<Window x:Class="食品信息管理系统.Views.Dialogs.SamplingRecordEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="取样记录编辑" Height="520" Width="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部按钮工具栏 -->
        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0">
                <Button Content="新增" Height="26" Width="60" Margin="5,0" Background="#4CAF50" Foreground="White" BorderThickness="0" Click="NewButton_Click"/>
                <Button Content="保存" Height="26" Width="60" Margin="5,0" Background="#2196F3" Foreground="White" BorderThickness="0" Click="SaveButton_Click"/>
                <Button Content="重置" Height="26" Width="60" Margin="5,0" Background="#FF9800" Foreground="White" BorderThickness="0" Click="ResetButton_Click"/>
                <Button Content="关闭" Height="26" Width="60" Margin="5,0" Background="#757575" Foreground="White" BorderThickness="0" Click="CloseButton_Click"/>
            </StackPanel>
        </Border>

        <!-- 表单 -->
        <Grid Grid.Row="1" Margin="16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="取样ID：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="SamplingIdText" VerticalContentAlignment="Center" IsReadOnly="True" Background="#EEEEEE"
                     Text="{Binding SamplingId, Mode=OneWay}"/>

            <TextBlock Grid.Row="0" Grid.Column="2" Text="节点编号：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <TextBox Grid.Row="0" Grid.Column="3" x:Name="NodeCodeText" VerticalContentAlignment="Center"
                     Text="{Binding NodeCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="取样日期：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <DatePicker Grid.Row="1" Grid.Column="1" x:Name="SamplingDatePicker" VerticalContentAlignment="Center"
                        SelectedDateFormat="Short"
                        SelectedDate="{Binding SamplingDate, Mode=TwoWay}"/>

            <TextBlock Grid.Row="1" Grid.Column="2" Text="检验日期：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <DatePicker Grid.Row="1" Grid.Column="3" x:Name="InspectionDatePicker" VerticalContentAlignment="Center"
                        SelectedDateFormat="Short"
                        SelectedDate="{Binding InspectionDate, Mode=TwoWay}"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="检品名称：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="SampleNameText" VerticalContentAlignment="Center"
                     Text="{Binding SampleName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="2" Grid.Column="2" Text="检品批号：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <TextBox Grid.Row="2" Grid.Column="3" x:Name="SampleBatchText" VerticalContentAlignment="Center"
                     Text="{Binding SampleBatch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="品牌系列：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <TextBox Grid.Row="3" Grid.Column="1" x:Name="BrandSeriesText" VerticalContentAlignment="Center"
                     Text="{Binding BrandSeries, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="3" Grid.Column="2" Text="取样量：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <TextBox Grid.Row="3" Grid.Column="3" x:Name="SamplingQuantityText" VerticalContentAlignment="Center"
                     PreviewTextInput="DecimalInput_PreviewTextInput"
                     Text="{Binding SamplingQuantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="代表量：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <TextBox Grid.Row="4" Grid.Column="1" x:Name="RepresentativeQuantityText" VerticalContentAlignment="Center"
                     PreviewTextInput="DecimalInput_PreviewTextInput"
                     Text="{Binding RepresentativeQuantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="4" Grid.Column="2" Text="检品来源：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <ComboBox Grid.Row="4" Grid.Column="3" x:Name="SampleSourceCombo" VerticalContentAlignment="Center"
                      IsEditable="True" IsTextSearchEnabled="True"
                      Text="{Binding SampleSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="取样人：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <ComboBox Grid.Row="5" Grid.Column="1" x:Name="SamplerCombo" VerticalContentAlignment="Center"
                      IsEditable="True" IsTextSearchEnabled="True"
                      Text="{Binding Sampler, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="备注：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <TextBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3" x:Name="RemarkText" VerticalContentAlignment="Top" TextWrapping="Wrap" AcceptsReturn="True" Height="80" Grid.RowSpan="2"
                     Text="{Binding Remark, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>
    </Grid>
</Window>
