<Window x:Class="食品信息管理系统.Views.Dialogs.ProductInfoEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="产品信息编辑" Height="620" Width="900"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="90"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="节点编码:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="NodeCodeText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="产品ID:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="0" Grid.Column="3" x:Name="ProductIdText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="产品名称:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="ProductNameText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="产品编码:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="1" Grid.Column="3" x:Name="ProductCodeText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="标准代码:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="StandardCodeText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="2" Text="食品分类:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <ComboBox Grid.Row="2" Grid.Column="3" x:Name="FoodCategoryCombo" IsEditable="True" IsTextSearchEnabled="True"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="剂型:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <ComboBox Grid.Row="3" Grid.Column="1" x:Name="DosageFormCombo" IsEditable="True" IsTextSearchEnabled="True"/>

                <TextBlock Grid.Row="3" Grid.Column="2" Text="权属状态:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <ComboBox Grid.Row="3" Grid.Column="3" x:Name="OwnershipStatusCombo" IsEditable="True" IsTextSearchEnabled="True"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="批准方式:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="ApprovalMethodCombo" IsEditable="True" IsTextSearchEnabled="True"/>

                <TextBlock Grid.Row="4" Grid.Column="2" Text="批准部门:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="4" Grid.Column="3" x:Name="ApprovalDepartmentText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="批准日期:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <DatePicker Grid.Row="5" Grid.Column="1" x:Name="ApprovalDatePicker" SelectedDateFormat="Short"/>

                <TextBlock Grid.Row="5" Grid.Column="2" Text="标准有效期:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="5" Grid.Column="3" x:Name="StandardValidityText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="企业编码:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="6" Grid.Column="1" x:Name="EnterpriseCodeText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="6" Grid.Column="2" Text="企业年限:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="6" Grid.Column="3" x:Name="EnterpriseYearText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="企业生效日:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <DatePicker Grid.Row="7" Grid.Column="1" x:Name="EnterpriseEffectiveDatePicker" SelectedDateFormat="Short"/>

                <TextBlock Grid.Row="7" Grid.Column="2" Text="排序号:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="7" Grid.Column="3" x:Name="SortOrderText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="标准链接:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="3" x:Name="StandardLinkText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="9" Grid.Column="0" Text="企业链接:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="3" x:Name="EnterpriseLinkText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="10" Grid.Column="0" Text="启用状态:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <CheckBox Grid.Row="10" Grid.Column="1" x:Name="IsEnabledCheck" Content="启用" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="10" Grid.Column="2" Text="备注:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="10" Grid.Column="3" x:Name="RemarkText" VerticalContentAlignment="Center"/>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="保存" Width="88" Margin="0,0,8,0" Click="SaveButton_Click"/>
            <Button Content="取消" Width="88" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
