<Window x:Class="食品信息管理系统.Views.Dialogs.TreeNodeEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:widgets="clr-namespace:FoodEnterpriseIMS.Widgets"
        Title="节点编辑" Height="520" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 固定字段 -->
        <Grid Grid.Row="0" Margin="12,12,12,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="父级编码：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="ParentCodeText" VerticalContentAlignment="Center" IsReadOnly="True" Background="#EEEEEE"/>

            <TextBlock Grid.Row="0" Grid.Column="2" Text="当前编码：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <TextBox Grid.Row="0" Grid.Column="3" x:Name="CodeText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="节点标题：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TitleText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="1" Grid.Column="2" Text="同级位置：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <TextBox Grid.Row="1" Grid.Column="3" x:Name="SortOrderText" VerticalContentAlignment="Center"
                     MaxLength="4" PreviewTextInput="NumericOnly_PreviewTextInput"/>
        </Grid>

        <!-- 其他字段标题 -->
        <TextBlock Grid.Row="1" Text="其他字段" FontWeight="Bold" FontSize="14" Margin="12,6,12,4" VerticalAlignment="Center"/>

        <!-- DataGrid 工具栏 -->
        <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,1,0,1" Margin="0,0,0,4">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0">
                <Button x:Name="AddRowButton" Content="新增行" Height="26" Width="70" Margin="4,0" Click="AddRowButton_Click"/>
                <Button x:Name="DeleteRowButton" Content="删除选中行" Height="26" Width="80" Margin="4,0" Click="DeleteRowButton_Click"/>
                <Button x:Name="AddMenuPathButton" Content="添加菜单路径" Height="26" Width="90" Margin="4,0" Click="AddMenuPathButton_Click"/>
                <Button x:Name="AddComponentPathButton" Content="选择模块窗体(C#)" Height="26" Width="120" Margin="4,0" Click="AddComponentPathButton_Click"/>
            </StackPanel>
        </Border>

        <!-- 键值对列表 -->
        <Border Grid.Row="3" Margin="12,0,12,8" BorderBrush="#CCCCCC" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="26"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- 标题行 -->
                <Grid Grid.Row="0" Background="#F0F0F0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="键" Grid.Column="0" Margin="6,0" VerticalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock Text="值" Grid.Column="1" Margin="6,0" VerticalAlignment="Center" FontWeight="Bold"/>
                    <Border Grid.Column="0" BorderBrush="#CCCCCC" BorderThickness="0,0,1,1"/>
                    <Border Grid.Column="1" BorderBrush="#CCCCCC" BorderThickness="0,0,0,1"/>
                </Grid>
                <!-- 可编辑列表 -->
                <ListBox Grid.Row="1" x:Name="PayloadListBox" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="#2196F3"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding Key, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Padding="4,2" BorderThickness="0,0,1,1"/>
                                <TextBox Grid.Column="1" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Padding="4,2" BorderThickness="0,0,0,1"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- 底部按钮 -->
        <Border Grid.Row="4" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5">
                <Button Content="新增" Height="26" Width="60" Margin="5,0" Background="#4CAF50" Foreground="White" BorderThickness="0" Click="NewButton_Click"/>
                <Button Content="保存" Height="26" Width="60" Margin="5,0" Background="#2196F3" Foreground="White" BorderThickness="0" Click="SaveButton_Click"/>
                <Button Content="重置" Height="26" Width="60" Margin="5,0" Background="#FF9800" Foreground="White" BorderThickness="0" Click="ResetButton_Click"/>
                <Button Content="关闭" Height="26" Width="60" Margin="5,0" Background="#757575" Foreground="White" BorderThickness="0" Click="CloseButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
