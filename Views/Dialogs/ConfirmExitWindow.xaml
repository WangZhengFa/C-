<Window x:Class="食品信息管理系统.Views.Dialogs.ConfirmExitWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认退出" Height="160" Width="320"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Closing="Window_Closing">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="是否退出系统？" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>

        <TextBlock Grid.Row="1" x:Name="CountdownText" Text="30 秒后自动退出" FontSize="12" Foreground="#E53935"
                   HorizontalAlignment="Center" Margin="0,8,0,12"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="BtnYes" Content="是" Width="70" Height="26" Margin="8,0" Background="#4CAF50" Foreground="White" Click="BtnYes_Click"/>
            <Button x:Name="BtnNo" Content="否" Width="70" Height="26" Margin="8,0" Background="#757575" Foreground="White" Click="BtnNo_Click"/>
        </StackPanel>
    </Grid>
</Window>
