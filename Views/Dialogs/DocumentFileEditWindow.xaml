<Window x:Class="食品信息管理系统.Views.Dialogs.DocumentFileEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编制文件编辑" Height="720" Width="980"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="90"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="90"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="节点编码:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="NodeCodeText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="文件唯一ID:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="0" Grid.Column="3" x:Name="FileUniqueIdText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="部门:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="DepartmentText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="标准分类:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="1" Grid.Column="3" x:Name="StdCategoryText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="一级分类:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="2" Grid.Column="1" x:Name="StdLevel1Text" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="2" Text="二级分类:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="2" Grid.Column="3" x:Name="StdLevel2Text" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="文件名称:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="3" Grid.Column="1" x:Name="FileNameText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="3" Grid.Column="2" Text="文件编号:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="3" Grid.Column="3" x:Name="FileCodeText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="版本:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="4" Grid.Column="1" x:Name="VersionText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="4" Grid.Column="2" Text="修订:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="4" Grid.Column="3" x:Name="RevisionText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="修订日期:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <DatePicker Grid.Row="5" Grid.Column="1" x:Name="RevisionDatePicker" SelectedDateFormat="Short"/>

                <TextBlock Grid.Row="5" Grid.Column="2" Text="生效日期:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <DatePicker Grid.Row="5" Grid.Column="3" x:Name="EffectiveDatePicker" SelectedDateFormat="Short"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="文件链接:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <TextBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3" x:Name="FileLinkText" VerticalContentAlignment="Center"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="状态:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                <CheckBox Grid.Row="7" Grid.Column="1" x:Name="IsInvalidCheck" Content="失效" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="备注:" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,6,8,0"/>
                <TextBox Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="3" x:Name="RemarkText" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="保存" Width="88" Margin="0,0,8,0" Click="SaveButton_Click"/>
            <Button Content="取消" Width="88" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
