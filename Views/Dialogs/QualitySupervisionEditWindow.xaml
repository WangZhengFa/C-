<Window x:Class="食品信息管理系统.Views.Dialogs.QualitySupervisionEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="质量监督编辑" Height="540" Width="640"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部按钮工具栏 -->
        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="5,0">
                <Button Content="新增" Height="26" Width="60" Margin="5,0" Background="#4CAF50" Foreground="White" BorderThickness="0" Click="NewButton_Click"/>
                <Button Content="保存" Height="26" Width="60" Margin="5,0" Background="#2196F3" Foreground="White" BorderThickness="0" Click="SaveButton_Click"/>
                <Button Content="重置" Height="26" Width="60" Margin="5,0" Background="#FF9800" Foreground="White" BorderThickness="0" Click="ResetButton_Click"/>
                <Button Content="关闭" Height="26" Width="60" Margin="5,0" Background="#757575" Foreground="White" BorderThickness="0" Click="CloseButton_Click"/>
            </StackPanel>
        </Border>

        <!-- 表单 -->
        <Grid Grid.Row="1" Margin="16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="28"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="监督ID：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="SupervisionIdText" VerticalContentAlignment="Center" IsReadOnly="True" Background="#EEEEEE"
                     Text="{Binding SupervisionId, Mode=OneWay}"/>

            <TextBlock Grid.Row="0" Grid.Column="2" Text="发现日期：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <DatePicker Grid.Row="0" Grid.Column="3" x:Name="DiscoveryDatePicker" VerticalContentAlignment="Center"
                        SelectedDate="{Binding DiscoveryDate, Mode=TwoWay}"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="项目类别：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="ProjectCategoryText" VerticalContentAlignment="Center"
                     Text="{Binding ProjectCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="1" Grid.Column="2" Text="项目名称：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <TextBox Grid.Row="1" Grid.Column="3" x:Name="ProjectNameText" VerticalContentAlignment="Center"
                     Text="{Binding ProjectName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="批号：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="BatchNumberText" VerticalContentAlignment="Center"
                     Text="{Binding BatchNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="2" Grid.Column="2" Text="数量：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <TextBox Grid.Row="2" Grid.Column="3" x:Name="QuantityText" VerticalContentAlignment="Center"
                     Text="{Binding Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="不符合项：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" x:Name="NonComplianceText" VerticalContentAlignment="Top" TextWrapping="Wrap" AcceptsReturn="True" Height="60" Grid.RowSpan="2"
                     Text="{Binding NonCompliance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="整改措施：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" x:Name="RectificationActionsText" VerticalContentAlignment="Top" TextWrapping="Wrap" AcceptsReturn="True" Height="60" Grid.RowSpan="2"
                     Text="{Binding RectificationActions, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="7" Grid.Column="0" Text="整改期限：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <DatePicker Grid.Row="7" Grid.Column="1" x:Name="RectificationDeadlinePicker" VerticalContentAlignment="Center"
                        SelectedDate="{Binding RectificationDeadline, Mode=TwoWay}"/>

            <TextBlock Grid.Row="7" Grid.Column="2" Text="整改结果：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <TextBox Grid.Row="7" Grid.Column="3" x:Name="RectificationResultText" VerticalContentAlignment="Center"
                     Text="{Binding RectificationResult, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="8" Grid.Column="0" Text="监督人：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <TextBox Grid.Row="8" Grid.Column="1" x:Name="SupervisorText" VerticalContentAlignment="Center"
                     Text="{Binding Supervisor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Grid.Row="8" Grid.Column="2" Text="已审核：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <CheckBox Grid.Row="8" Grid.Column="3" x:Name="IsReviewedCheck" VerticalAlignment="Center"
                      IsChecked="{Binding IsReviewed, Mode=TwoWay}"/>

            <TextBlock Grid.Row="9" Grid.Column="0" Text="备注：" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            <TextBox Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="3" x:Name="RemarksText" VerticalContentAlignment="Top" TextWrapping="Wrap" AcceptsReturn="True" Height="60" Grid.RowSpan="2"
                     Text="{Binding Remarks, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>
    </Grid>
</Window>
