<Window x:Class="食品信息管理系统.Views.Dialogs.ProductBarcodeEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="产品条码编辑" Height="500" Width="820"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="90"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="条码ID:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="0" Grid.Column="1" x:Name="BarcodeIdText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="0" Grid.Column="2" Text="企业编码:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="0" Grid.Column="3" x:Name="CompanyCodeText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="条码号:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="1" Grid.Column="1" x:Name="BarcodeNumberText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="1" Grid.Column="2" Text="产品ID:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="1" Grid.Column="3" x:Name="ProductIdText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="产品名称:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="2" Grid.Column="1" x:Name="ProductNameText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="2" Grid.Column="2" Text="品牌系列:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="2" Grid.Column="3" x:Name="BrandSeriesText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="包装类别:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="3" Grid.Column="1" x:Name="PackageCategoryText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="3" Grid.Column="2" Text="包装规格:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="3" Grid.Column="3" x:Name="PackageSpecText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="净含量:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <TextBox Grid.Row="4" Grid.Column="1" x:Name="NetContentText" VerticalContentAlignment="Center"/>

            <TextBlock Grid.Row="4" Grid.Column="2" Text="单位:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <ComboBox Grid.Row="4" Grid.Column="3" x:Name="UnitCombo" IsEditable="True" IsTextSearchEnabled="True"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="生成日期:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <DatePicker Grid.Row="5" Grid.Column="1" x:Name="GenerateDatePicker" SelectedDateFormat="Short"/>

            <TextBlock Grid.Row="5" Grid.Column="2" Text="停用状态:" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
            <CheckBox Grid.Row="5" Grid.Column="3" x:Name="IsDisabledCheck" Content="已停用" VerticalAlignment="Center"/>

            <TextBlock Grid.Row="7" Grid.Column="0" Text="备注:" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,6,8,0"/>
            <TextBox Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="3" x:Name="RemarkText" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="保存" Width="88" Margin="0,0,8,0" Click="SaveButton_Click"/>
            <Button Content="取消" Width="88" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
