<Window x:Class="食品信息管理系统.Views.DbSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="数据库连接配置" Height="260" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">

    <Grid Margin="12,8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="26"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="26"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="26"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="26"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="26"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="4"
                   Text="数据库连接配置"
                   FontSize="16"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,8"/>

        <!-- 第一行：主机 + 端口 -->
        <Border Grid.Row="1" Grid.Column="0" Background="#B8E0B8">
            <TextBlock Text="主机：" VerticalAlignment="Center" FontSize="12" Padding="6,0"/>
        </Border>
        <Border Grid.Row="1" Grid.Column="1" Background="#D8F0D8">
            <ComboBox x:Name="HostEntry" FontSize="12" VerticalContentAlignment="Center" Padding="2,0" BorderThickness="0" Background="Transparent"
                      IsEditable="True" IsTextSearchEnabled="True"/>
        </Border>
        <Border Grid.Row="1" Grid.Column="2" Background="#B8E0B8" Margin="1,0,0,0">
            <TextBlock Text="端口：" VerticalAlignment="Center" FontSize="12" Padding="6,0"/>
        </Border>
        <Border Grid.Row="1" Grid.Column="3" Background="#D8F0D8">
            <ComboBox x:Name="PortEntry" FontSize="12" VerticalContentAlignment="Center" Padding="2,0" BorderThickness="0" Background="Transparent"
                      IsEditable="True" IsTextSearchEnabled="True"
                      PreviewTextInput="NumericOnly_PreviewTextInput"/>
        </Border>

        <!-- 第二行：用户 + 密码 -->
        <Border Grid.Row="3" Grid.Column="0" Background="#B8E0B8">
            <TextBlock Text="用户：" VerticalAlignment="Center" FontSize="12" Padding="6,0"/>
        </Border>
        <Border Grid.Row="3" Grid.Column="1" Background="#D8F0D8">
            <TextBox x:Name="UserEntry" FontSize="12" VerticalContentAlignment="Center" Padding="4,0" BorderThickness="0" Background="Transparent"/>
        </Border>
        <Border Grid.Row="3" Grid.Column="2" Background="#B8E0B8" Margin="1,0,0,0">
            <TextBlock Text="密码：" VerticalAlignment="Center" FontSize="12" Padding="6,0"/>
        </Border>
        <Border Grid.Row="3" Grid.Column="3" Background="#D8F0D8">
            <PasswordBox x:Name="PasswordEntry" FontSize="12" VerticalContentAlignment="Center" Padding="4,0" BorderThickness="0" Background="Transparent"/>
        </Border>

        <!-- 第三行：库名 -->
        <Border Grid.Row="5" Grid.Column="0" Background="#B8E0B8">
            <TextBlock Text="库名：" VerticalAlignment="Center" FontSize="12" Padding="6,0"/>
        </Border>
        <Border Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" Background="#D8F0D8">
            <ComboBox x:Name="DatabaseEntry" FontSize="12" VerticalContentAlignment="Center" Padding="2,0" BorderThickness="0" Background="Transparent"
                      IsEditable="True" IsTextSearchEnabled="True"/>
        </Border>

        <!-- 第四行：自动登录倒计时 -->
        <Border Grid.Row="7" Grid.Column="0" Background="#B8E0B8">
            <TextBlock Text="自动登录倒计时：" VerticalAlignment="Center" FontSize="12" Padding="6,0"/>
        </Border>
        <Border Grid.Row="7" Grid.Column="1" Background="#D8F0D8">
            <ComboBox x:Name="CountdownEntry" FontSize="12" VerticalContentAlignment="Center" Padding="2,0" BorderThickness="0" Background="Transparent"
                      IsEditable="True" IsTextSearchEnabled="True"
                      PreviewTextInput="NumericOnly_PreviewTextInput"/>
        </Border>
        <Border Grid.Row="7" Grid.Column="2" Background="#B8E0B8" Margin="1,0,0,0">
            <TextBlock Text="秒" VerticalAlignment="Center" FontSize="12" Padding="6,0" HorizontalAlignment="Center"/>
        </Border>
        <Border Grid.Row="7" Grid.Column="3" Background="#D8F0D8"/>

        <!-- 第五行：自动更新 -->
        <Border Grid.Row="9" Grid.Column="0" Background="#B8E0B8">
            <TextBlock Text="自动更新：" VerticalAlignment="Center" FontSize="12" Padding="6,0"/>
        </Border>
        <Border Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="3" Background="#D8F0D8">
            <CheckBox x:Name="AutoUpdateCheck" Content="启用自动更新" FontSize="12" VerticalAlignment="Center" Padding="6,0"/>
        </Border>

        <!-- 按钮 -->
        <StackPanel Grid.Row="10" Grid.ColumnSpan="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,0">
            <Button x:Name="TestBtn" Content="测试连接" FontSize="12" Background="#2196F3" Foreground="White" Height="26" Width="80" Margin="4,0" Click="OnTestClicked"/>
            <Button x:Name="SaveBtn" Content="保存设置" FontSize="12" Background="#4CAF50" Foreground="White" Height="26" Width="80" Margin="4,0" Click="OnSaveClicked"/>
            <Button x:Name="CancelBtn" Content="返回" FontSize="12" Background="#9E9E9E" Foreground="White" Height="26" Width="80" Margin="4,0" Click="OnCancelClicked"/>
        </StackPanel>

        <TextBlock Grid.Row="11" Grid.ColumnSpan="4"
                   x:Name="MessageLabel"
                   Foreground="Red"
                   FontSize="11"
                   HorizontalAlignment="Center"
                   Visibility="Collapsed"
                   Margin="0,5,0,0"/>
    </Grid>
</Window>
