<Page x:Class="食品信息管理系统.Views.Pages.UserManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="用户管理入口">
    <Grid Margin="16">
        <Border Background="#0F172A" CornerRadius="12" Padding="20">
            <StackPanel>
                <TextBlock Text="用户与权限管理" Foreground="White" FontSize="24" FontWeight="Bold"/>
                <TextBlock Text="当前菜单作为用户管理入口，实际管理界面复用现有的多标签窗口，便于继续维护用户、角色和权限。" Foreground="#D1D5DB" Margin="0,8,0,0" TextWrapping="Wrap"/>
                <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                    <Button Content="打开用户管理窗口" Width="150" Height="34" Background="#4CAF50" Foreground="White" BorderThickness="0" Click="OpenWindow_Click"/>
                    <Button Content="刷新权限提示" Width="120" Height="34" Margin="12,0,0,0" Click="RefreshButton_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
