<Page x:Class="食品信息管理系统.Views.Pages.SamplingRecordPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="取样记录">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                <Button Content="新增" Tag="add_btn" Height="26" Width="60" Margin="5,0" Background="#4CAF50" Foreground="White" BorderThickness="0" Click="AddButton_Click"/>
                <Button Content="编辑" Tag="edit_btn" Height="26" Width="60" Margin="5,0" Background="#2196F3" Foreground="White" BorderThickness="0" Click="EditButton_Click"/>
                <Button Content="删除" Tag="delete_btn" Height="26" Width="60" Margin="5,0" Background="#E53935" Foreground="White" BorderThickness="0" Click="DeleteButton_Click"/>
                <Button Content="导入" Tag="import_btn" Height="26" Width="60" Margin="5,0" Background="#FF9800" Foreground="White" BorderThickness="0" Click="ImportButton_Click"/>
                <Button Content="导出" Tag="export_btn" Height="26" Width="60" Margin="5,0" Background="#9C27B0" Foreground="White" BorderThickness="0" Click="ExportButton_Click"/>
                <Button Content="设置" Tag="settings_btn" Height="26" Width="60" Margin="5,0" Background="#607D8B" Foreground="White" BorderThickness="0" Click="SettingsButton_Click"/>
                <Button Content="关闭" Tag="close_btn" Height="26" Width="60" Margin="5,0" Background="#757575" Foreground="White" BorderThickness="0" Click="CloseButton_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="8,6">
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="关键字:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="KeywordFilterText" Width="180" VerticalContentAlignment="Center" Margin="0,0,12,0"
                         TextChanged="OnFilterChanged"/>

                <TextBlock Text="来源:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="SampleSourceFilterCombo" Width="140" IsEditable="True" IsTextSearchEnabled="True" Margin="0,0,12,0"
                          SelectionChanged="OnFilterChanged" LostFocus="OnFilterChanged"/>

                <TextBlock Text="取样日期:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <DatePicker x:Name="SamplingDateFromPicker" Width="130" SelectedDateFormat="Short" Margin="0,0,4,0"
                            SelectedDateChanged="OnFilterChanged"/>
                <TextBlock Text="~" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <DatePicker x:Name="SamplingDateToPicker" Width="130" SelectedDateFormat="Short" Margin="0,0,12,0"
                            SelectedDateChanged="OnFilterChanged"/>

                <Button Content="清空筛选" Width="86" Click="ClearFilters_Click"/>
            </WrapPanel>
        </Border>

        <!-- 主体 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧物料节点树 -->
            <Border Grid.Column="0" BorderBrush="#DDDDDD" BorderThickness="0,0,1,0">
                <TreeView x:Name="NodeTree" SelectedItemChanged="NodeTree_SelectedItemChanged">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="True"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </Border>

            <!-- 右侧数据表格 -->
            <DataGrid Grid.Column="1" x:Name="RecordGrid" AutoGenerateColumns="False" IsReadOnly="True"
                      GridLinesVisibility="Horizontal" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="取样ID" Binding="{Binding SamplingId}" Width="120"/>
                    <DataGridTextColumn Header="节点编号" Binding="{Binding NodeCode}" Width="100"/>
                    <DataGridTextColumn Header="取样日期" Binding="{Binding SamplingDate, StringFormat=yyyy-MM-dd}" Width="90"/>
                    <DataGridTextColumn Header="检验日期" Binding="{Binding InspectionDate, StringFormat=yyyy-MM-dd}" Width="90"/>
                    <DataGridTextColumn Header="检品名称" Binding="{Binding SampleName}" Width="*"/>
                    <DataGridTextColumn Header="检品批号" Binding="{Binding SampleBatch}" Width="100"/>
                    <DataGridTextColumn Header="品牌系列" Binding="{Binding BrandSeries}" Width="100"/>
                    <DataGridTextColumn Header="取样量" Binding="{Binding SamplingQuantity}" Width="80"/>
                    <DataGridTextColumn Header="代表量" Binding="{Binding RepresentativeQuantity}" Width="80"/>
                    <DataGridTextColumn Header="检品来源" Binding="{Binding SampleSource}" Width="100"/>
                    <DataGridTextColumn Header="取样人" Binding="{Binding Sampler}" Width="80"/>
                    <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Page>
