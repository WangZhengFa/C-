<Page x:Class="食品信息管理系统.Views.Pages.UpdateManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="更新管理">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                <Button Content="刷新" Tag="refresh_btn" Height="26" Width="60" Margin="5,0" Background="#607D8B" Foreground="White" BorderThickness="0" Click="RefreshButton_Click"/>
                <Button Content="保存" Tag="save_btn" Height="26" Width="60" Margin="5,0" Background="#4CAF50" Foreground="White" BorderThickness="0" Click="SaveButton_Click"/>
                <Button Content="关闭" Tag="close_btn" Height="26" Width="60" Margin="5,0" Background="#757575" Foreground="White" BorderThickness="0" Click="CloseButton_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="8,6">
            <TextBlock Text="更新管理维护系统更新相关配置项，如最新版本号、下载地址、强制更新和更新说明。" Foreground="#666666"/>
        </Border>

        <DataGrid Grid.Row="2" x:Name="RecordGrid" AutoGenerateColumns="False" IsReadOnly="False"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal" BorderThickness="0" SelectionMode="Single" SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="配置键" Binding="{Binding ConfigKey}" Width="160" IsReadOnly="True"/>
                <DataGridTextColumn Header="显示名称" Binding="{Binding DisplayName}" Width="140" IsReadOnly="True"/>
                <DataGridTextColumn Header="配置值" Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                <DataGridTextColumn Header="说明" Binding="{Binding Description}" Width="260" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
