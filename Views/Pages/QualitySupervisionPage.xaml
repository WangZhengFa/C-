<Page x:Class="食品信息管理系统.Views.Pages.QualitySupervisionPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="质量监督">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                <Button Content="新增" Tag="add_btn" Height="26" Width="60" Margin="5,0" Background="#4CAF50" Foreground="White" BorderThickness="0" Click="AddButton_Click"/>
                <Button Content="编辑" Tag="edit_btn" Height="26" Width="60" Margin="5,0" Background="#2196F3" Foreground="White" BorderThickness="0" Click="EditButton_Click"/>
                <Button Content="删除" Tag="delete_btn" Height="26" Width="60" Margin="5,0" Background="#E53935" Foreground="White" BorderThickness="0" Click="DeleteButton_Click"/>
                <Button Content="导入" Tag="import_btn" Height="26" Width="60" Margin="5,0" Background="#FF9800" Foreground="White" BorderThickness="0" Click="ImportButton_Click"/>
                <Button Content="导出" Tag="export_btn" Height="26" Width="60" Margin="5,0" Background="#9C27B0" Foreground="White" BorderThickness="0" Click="ExportButton_Click"/>
                <Button Content="设置" Tag="settings_btn" Height="26" Width="60" Margin="5,0" Background="#607D8B" Foreground="White" BorderThickness="0" Click="SettingsButton_Click"/>
                <Button Content="关闭" Tag="close_btn" Height="26" Width="60" Margin="5,0" Background="#757575" Foreground="White" BorderThickness="0" Click="CloseButton_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="8,6">
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="关键字:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="KeywordFilterText" Width="180" VerticalContentAlignment="Center" Margin="0,0,12,0"
                         TextChanged="OnFilterChanged"/>

                <TextBlock Text="项目类别:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="ProjectCategoryFilterCombo" Width="140" IsEditable="True" IsTextSearchEnabled="True" Margin="0,0,12,0"
                          SelectionChanged="OnFilterChanged" LostFocus="OnFilterChanged"/>

                <TextBlock Text="整改结果:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="RectificationResultFilterCombo" Width="120" IsEditable="True" IsTextSearchEnabled="True" Margin="0,0,12,0"
                          SelectionChanged="OnFilterChanged" LostFocus="OnFilterChanged"/>

                <TextBlock Text="发现日期:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <DatePicker x:Name="DiscoveryDateFromPicker" Width="130" SelectedDateFormat="Short" Margin="0,0,4,0"
                            SelectedDateChanged="OnFilterChanged"/>
                <TextBlock Text="~" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <DatePicker x:Name="DiscoveryDateToPicker" Width="130" SelectedDateFormat="Short" Margin="0,0,12,0"
                            SelectedDateChanged="OnFilterChanged"/>

                <Button Content="清空筛选" Width="86" Click="ClearFilters_Click"/>
            </WrapPanel>
        </Border>

        <!-- 右侧数据表格 -->
        <DataGrid Grid.Row="2" x:Name="RecordGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  GridLinesVisibility="Horizontal" BorderThickness="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="监督ID" Binding="{Binding SupervisionId}" Width="120"/>
                <DataGridTextColumn Header="发现日期" Binding="{Binding DiscoveryDate, StringFormat=yyyy-MM-dd}" Width="90"/>
                <DataGridTextColumn Header="项目类别" Binding="{Binding ProjectCategory}" Width="100"/>
                <DataGridTextColumn Header="项目名称" Binding="{Binding ProjectName}" Width="*"/>
                <DataGridTextColumn Header="批号" Binding="{Binding BatchNumber}" Width="100"/>
                <DataGridTextColumn Header="数量" Binding="{Binding Quantity}" Width="80"/>
                <DataGridTextColumn Header="不符合项" Binding="{Binding NonCompliance}" Width="150"/>
                <DataGridTextColumn Header="整改措施" Binding="{Binding RectificationActions}" Width="150"/>
                <DataGridTextColumn Header="整改期限" Binding="{Binding RectificationDeadline, StringFormat=yyyy-MM-dd}" Width="90"/>
                <DataGridTextColumn Header="整改结果" Binding="{Binding RectificationResult}" Width="100"/>
                <DataGridTextColumn Header="监督人" Binding="{Binding Supervisor}" Width="80"/>
                <DataGridCheckBoxColumn Header="已审核" Binding="{Binding IsReviewed}" Width="60"/>
                <DataGridTextColumn Header="备注" Binding="{Binding Remarks}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
