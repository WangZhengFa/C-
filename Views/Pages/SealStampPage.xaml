<Page x:Class="食品信息管理系统.Views.Pages.SealStampPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="加盖公章">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <CheckBox Grid.Row="0" x:Name="EnabledCheck" Content="启用公章叠加" VerticalAlignment="Center"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="图片路径:" Width="90" VerticalAlignment="Center"/>
                <TextBox x:Name="ImagePathText" Width="240" VerticalContentAlignment="Center"/>
                <Button Content="浏览" Width="60" Margin="8,0,0,0" Click="BrowseImage_Click"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="透明度:" Width="90" VerticalAlignment="Center"/>
                <TextBox x:Name="OpacityText" Width="120" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="水平偏移:" Width="90" VerticalAlignment="Center"/>
                <TextBox x:Name="OffsetXText" Width="120" VerticalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="垂直偏移:" Width="90" VerticalAlignment="Center"/>
                <TextBox x:Name="OffsetYText" Width="120" VerticalContentAlignment="Center"/>
            </StackPanel>

            <TextBlock Grid.Row="5" Text="说明：启用后可在导出或打印流程中叠加指定公章图片。" TextWrapping="Wrap" Foreground="#666666" Margin="0,10,0,0"/>

            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,12,0,0">
                <Button Content="刷新" Width="88" Margin="0,0,8,0" Click="RefreshButton_Click"/>
                <Button Content="保存" Width="88" Margin="0,0,8,0" Background="#4CAF50" Foreground="White" BorderThickness="0" Click="SaveButton_Click"/>
            </StackPanel>
        </Grid>

        <Border Grid.Column="2" BorderBrush="#D0D0D0" BorderThickness="1" CornerRadius="4" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="公章预览" FontWeight="Bold" Margin="0,0,0,8"/>
                <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="1">
                    <Image x:Name="PreviewImage" Stretch="Uniform"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
