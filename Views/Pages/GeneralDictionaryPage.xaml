<Page x:Class="食品信息管理系统.Views.Pages.GeneralDictionaryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
      Title="通用字典">
    <Page.Resources>
        <Style x:Key="ClassicDictTreeViewStyle" TargetType="TreeView">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeView">
                        <Border BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}">
                            <ScrollViewer CanContentScroll="True"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsPresenter Margin="{TemplateBinding Padding}"/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ClassicDictTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="MinHeight" Value="22"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Rectangle x:Name="HorLn"
                                       Grid.Column="0" Grid.Row="0"
                                       Height="1"
                                       Fill="#8E8E8E"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Width="9"
                                       Margin="0,0,0,0"/>

                            <Rectangle x:Name="VerLn"
                                       Grid.Column="0" Grid.Row="0"
                                       Width="1"
                                       Fill="#8E8E8E"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Stretch"/>

                            <ToggleButton x:Name="Expander"
                                          Grid.Column="0" Grid.Row="0"
                                          Width="9" Height="9"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center"
                                          Margin="0,0,0,0"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Width="9" Height="9" Background="White" BorderBrush="#6F6F6F" BorderThickness="1">
                                            <Grid>
                                                <Rectangle Width="5" Height="1" Fill="#333" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <Rectangle x:Name="PlusLine" Width="1" Height="5" Fill="#333" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="PlusLine" Property="Visibility" Value="Collapsed"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Border x:Name="Bd"
                                    Grid.Column="1" Grid.Row="0"
                                    Background="Transparent"
                                    Padding="2,2,2,2">
                                <ContentPresenter x:Name="PART_Header"
                                                  ContentSource="Header"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"/>
                            </Border>

                            <ItemsPresenter x:Name="ItemsHost"
                                            Grid.ColumnSpan="2"
                                            Grid.Row="1"
                                            Margin="18,0,0,0"
                                            Visibility="Collapsed"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#CFE8FF"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EAF4FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="38"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#D0D0D0" BorderThickness="0,0,0,1" Padding="4,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="240"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="添加" Tag="add_btn" Height="26" Width="56" Margin="2,0" Background="#2FA84F" Foreground="White" BorderThickness="0" Click="AddButton_Click"/>
                    <Button Content="编辑" Tag="edit_btn" Height="26" Width="56" Margin="2,0" Background="#2196F3" Foreground="White" BorderThickness="0" Click="EditButton_Click"/>
                    <Button Content="删除" Tag="delete_btn" Height="26" Width="56" Margin="2,0" Background="#E53935" Foreground="White" BorderThickness="0" Click="DeleteButton_Click"/>
                    <Button Content="上移" Height="26" Width="56" Margin="2,0" Background="#2E73B8" Foreground="White" BorderThickness="0" Click="MoveUpButton_Click"/>
                    <Button Content="下移" Height="26" Width="56" Margin="2,0" Background="#2E73B8" Foreground="White" BorderThickness="0" Click="MoveDownButton_Click"/>
                    <Button Content="导入" Tag="import_btn" Height="26" Width="56" Margin="2,0" Background="#138FC2" Foreground="White" BorderThickness="0" Click="ImportButton_Click"/>
                    <Button Content="导出" Tag="export_btn" Height="26" Width="56" Margin="2,0" Background="#138FC2" Foreground="White" BorderThickness="0" Click="ExportButton_Click"/>
                    <Button Content="定义字段" Tag="settings_btn" Height="26" Width="74" Margin="2,0" Background="#F59E0B" Foreground="White" BorderThickness="0" Click="FieldDefsButton_Click"/>
                    <Button Content="列设置" Tag="settings_btn" Height="26" Width="64" Margin="2,0" Background="#F59E0B" Foreground="White" BorderThickness="0" Click="ColumnSettingsButton_Click"/>
                    <Button Content="保存" Tag="save_btn" Height="26" Width="56" Margin="2,0" Background="#2E73B8" Foreground="White" BorderThickness="0" Click="SaveButton_Click"/>
                    <Button Content="关闭" Tag="close_btn" Height="26" Width="56" Margin="2,0" Background="#2E73B8" Foreground="White" BorderThickness="0" Click="CloseButton_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBox x:Name="KeywordFilterText"
                             Width="188"
                             Height="26"
                             VerticalContentAlignment="Center"
                             Margin="0,0,6,0"
                             TextChanged="KeywordFilterText_TextChanged"
                             KeyDown="KeywordFilterText_KeyDown"/>
                    <Button Content="搜索" Width="46" Height="26" Background="#138FC2" Foreground="White" BorderThickness="0" Click="SearchButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="ColCategoryTree" Width="120" MinWidth="120" MaxWidth="420"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#BDBDBD" BorderThickness="0,0,1,0" Background="#F6F7F8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="34"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#2E73B8">
                        <TextBlock Text="字典分类" Foreground="White" FontWeight="Bold" VerticalAlignment="Center" Margin="6,0"/>
                    </Border>

                    <wfi:WindowsFormsHost x:Name="CategoryTreeHost" Grid.Row="1" Margin="2"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" BorderBrush="#BDBDBD" BorderThickness="1,0,0,0" Background="White">
                <DataGrid x:Name="RecordGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="All"
                          HeadersVisibility="Column"
                          BorderThickness="0"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="排序" Binding="{Binding SortOrder}" Width="60"/>
                        <DataGridTextColumn Header="编码" Binding="{Binding Code}" Width="90"/>
                        <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="120"/>
                        <DataGridTextColumn Header="字段1" Binding="{Binding Field1}" Width="100"/>
                        <DataGridTextColumn Header="字段2" Binding="{Binding Field2}" Width="100"/>
                        <DataGridTextColumn Header="字段3" Binding="{Binding Field3}" Width="100"/>
                        <DataGridTextColumn Header="字段4" Binding="{Binding Field4}" Width="100"/>
                        <DataGridTextColumn Header="字段5" Binding="{Binding Field5}" Width="100"/>
                        <DataGridTextColumn Header="数值1" Binding="{Binding Number1}" Width="90"/>
                        <DataGridTextColumn Header="数值2" Binding="{Binding Number2}" Width="90"/>
                        <DataGridTextColumn Header="日期1" Binding="{Binding Date1, StringFormat=yyyy-MM-dd}" Width="100"/>
                        <DataGridTextColumn Header="日期2" Binding="{Binding Date2, StringFormat=yyyy-MM-dd}" Width="100"/>
                        <DataGridCheckBoxColumn Header="标记1" Binding="{Binding Flag1}" Width="70"/>
                        <DataGridCheckBoxColumn Header="标记2" Binding="{Binding Flag2}" Width="70"/>
                        <DataGridTextColumn Header="金额" Binding="{Binding Amount}" Width="90"/>
                        <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="120"/>
                        <DataGridTextColumn Header="节点编码" Binding="{Binding NodeCode}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#F5F5F5" BorderBrush="#D0D0D0" BorderThickness="0,1,0,0" Padding="6,4">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox x:Name="AutoCodeCheckBox" Content="自动编码" Margin="0,0,8,0" VerticalAlignment="Center"
                              Checked="AutoCodeCheckBox_Changed" Unchecked="AutoCodeCheckBox_Changed"/>

                    <ComboBox x:Name="PrefixModeCombo" Width="72" Height="24" Margin="0,0,6,0"
                              SelectionChanged="PrefixModeCombo_SelectionChanged">
                        <ComboBoxItem Content="首字母" IsSelected="True"/>
                        <ComboBoxItem Content="手动"/>
                    </ComboBox>

                    <TextBlock Text="字数:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="PrefixLengthText" Width="34" Height="24" VerticalContentAlignment="Center" Text="2" Margin="0,0,8,0"/>

                    <TextBlock Text="位数:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="DigitsText" Width="34" Height="24" VerticalContentAlignment="Center" Text="3" Margin="0,0,8,0"/>

                    <TextBlock Text="手动前缀:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="PrefixText" Width="84" Height="24" VerticalContentAlignment="Center" Margin="0,0,8,0"/>

                    <CheckBox x:Name="ReorderCheckBox" Content="重新排序" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <Button x:Name="RecodeButton" Content="重排编码" Height="24" Width="72" Margin="0,0,6,0" Click="RecodeButton_Click"/>
                    <Button x:Name="SaveAutoCodeConfigButton" Content="保存配置" Height="24" Width="72" Click="SaveAutoCodeConfigButton_Click"/>
                </StackPanel>

                <TextBlock DockPanel.Dock="Right" Text="提示：左侧选择分类后可读取该节点的自定义字段。" Foreground="#555" VerticalAlignment="Center" Margin="12,0,0,0"/>
            </DockPanel>
        </Border>
    </Grid>
</Page>
