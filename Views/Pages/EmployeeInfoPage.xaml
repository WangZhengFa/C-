<Page x:Class="食品信息管理系统.Views.Pages.EmployeeInfoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="员工信息">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                <Button Content="新增" Tag="add_btn" Height="26" Width="60" Margin="5,0" Background="#4CAF50" Foreground="White" BorderThickness="0" Click="AddButton_Click"/>
                <Button Content="编辑" Tag="edit_btn" Height="26" Width="60" Margin="5,0" Background="#2196F3" Foreground="White" BorderThickness="0" Click="EditButton_Click"/>
                <Button Content="删除" Tag="delete_btn" Height="26" Width="60" Margin="5,0" Background="#E53935" Foreground="White" BorderThickness="0" Click="DeleteButton_Click"/>
                <Button Content="刷新" Tag="refresh_btn" Height="26" Width="60" Margin="5,0" Background="#607D8B" Foreground="White" BorderThickness="0" Click="RefreshButton_Click"/>
                <Button Content="关闭" Tag="close_btn" Height="26" Width="60" Margin="5,0" Background="#757575" Foreground="White" BorderThickness="0" Click="CloseButton_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="8,6">
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="关键字:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="KeywordFilterText" Width="200" VerticalContentAlignment="Center" Margin="0,0,12,0"
                         TextChanged="OnFilterChanged"/>

                <TextBlock Text="部门:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="DepartmentFilterCombo" Width="140" IsEditable="True" IsTextSearchEnabled="True" Margin="0,0,12,0"
                          SelectionChanged="OnFilterChanged" LostFocus="OnFilterChanged"/>

                <TextBlock Text="状态:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="StatusFilterCombo" Width="120" IsEditable="False" Margin="0,0,12,0"
                          SelectionChanged="OnFilterChanged"/>

                <Button Content="清空筛选" Width="86" Click="ClearFilters_Click"/>
            </WrapPanel>
        </Border>

        <DataGrid Grid.Row="2" x:Name="RecordGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  GridLinesVisibility="Horizontal" BorderThickness="0" SelectionMode="Single" SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                <DataGridTextColumn Header="工号" Binding="{Binding EmployeeId}" Width="100"/>
                <DataGridTextColumn Header="姓名" Binding="{Binding EmployeeName}" Width="100"/>
                <DataGridTextColumn Header="部门" Binding="{Binding Department}" Width="120"/>
                <DataGridTextColumn Header="职称" Binding="{Binding Title}" Width="90"/>
                <DataGridTextColumn Header="岗位" Binding="{Binding Position}" Width="90"/>
                <DataGridTextColumn Header="入职日期" Binding="{Binding HireDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridTextColumn Header="电话" Binding="{Binding Phone}" Width="120"/>
                <DataGridTextColumn Header="学历" Binding="{Binding Education}" Width="90"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>