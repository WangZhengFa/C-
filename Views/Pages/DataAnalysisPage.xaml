<Page x:Class="食品信息管理系统.Views.Pages.DataAnalysisPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="数据分析">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                <Button Content="刷新" Tag="refresh_btn" Height="26" Width="60" Margin="5,0" Background="#607D8B" Foreground="White" BorderThickness="0" Click="RefreshButton_Click"/>
                <Button Content="关闭" Tag="close_btn" Height="26" Width="60" Margin="5,0" Background="#757575" Foreground="White" BorderThickness="0" Click="CloseButton_Click"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="#0F172A" CornerRadius="12" Padding="18" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="数据分析总览" Foreground="White" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="汇总当前系统的核心业务数据，帮助快速掌握数据规模与最新版本信息。" Foreground="#D1D5DB" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <UniformGrid Grid.Row="2" Columns="3" Rows="4">
                <Border Margin="8" Padding="14" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="用户数量" Foreground="#6B7280"/>
                        <TextBlock x:Name="UserCountText" Text="0" FontSize="24" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="user_accounts" Foreground="#9CA3AF" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Margin="8" Padding="14" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="产品数量" Foreground="#6B7280"/>
                        <TextBlock x:Name="ProductCountText" Text="0" FontSize="24" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="product_infos" Foreground="#9CA3AF" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Margin="8" Padding="14" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="物料数量" Foreground="#6B7280"/>
                        <TextBlock x:Name="MaterialCountText" Text="0" FontSize="24" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="material_infos" Foreground="#9CA3AF" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Margin="8" Padding="14" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="客户数量" Foreground="#6B7280"/>
                        <TextBlock x:Name="CustomerCountText" Text="0" FontSize="24" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="customer_infos" Foreground="#9CA3AF" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Margin="8" Padding="14" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="文件数量" Foreground="#6B7280"/>
                        <TextBlock x:Name="DocumentCountText" Text="0" FontSize="24" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="document_files" Foreground="#9CA3AF" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Margin="8" Padding="14" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="考试配置" Foreground="#6B7280"/>
                        <TextBlock x:Name="ExamConfigCountText" Text="0" FontSize="24" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="exam_config" Foreground="#9CA3AF" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Margin="8" Padding="14" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="题库数量" Foreground="#6B7280"/>
                        <TextBlock x:Name="QuestionCountText" Text="0" FontSize="24" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="exam_question_bank" Foreground="#9CA3AF" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Margin="8" Padding="14" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="报告数据" Foreground="#6B7280"/>
                        <TextBlock x:Name="ReportDataCountText" Text="0" FontSize="24" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="report_data_main" Foreground="#9CA3AF" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Margin="8" Padding="14" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="版本日志" Foreground="#6B7280"/>
                        <TextBlock x:Name="VersionLogCountText" Text="0" FontSize="24" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="version_log" Foreground="#9CA3AF" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Margin="8" Padding="14" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="最新版本" Foreground="#6B7280"/>
                        <TextBlock x:Name="LatestVersionText" Text="-" FontSize="24" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock x:Name="LatestVersionDateText" Text="" Foreground="#9CA3AF" FontSize="12"/>
                    </StackPanel>
                </Border>
                <Border Margin="8" Padding="14" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10">
                    <StackPanel>
                        <TextBlock Text="系统配置" Foreground="#6B7280"/>
                        <TextBlock x:Name="SystemConfigCountText" Text="0" FontSize="24" FontWeight="Bold" Margin="0,6,0,0"/>
                        <TextBlock Text="system_config" Foreground="#9CA3AF" FontSize="12"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Grid>
    </Grid>
</Page>
