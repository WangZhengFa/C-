<Page x:Class="食品信息管理系统.Views.Pages.ReportIssuancePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="报告发放">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                <Button Content="新增" Tag="add_btn" Height="26" Width="60" Margin="5,0" Background="#4CAF50" Foreground="White" BorderThickness="0" Click="AddButton_Click"/>
                <Button Content="编辑" Tag="edit_btn" Height="26" Width="60" Margin="5,0" Background="#2196F3" Foreground="White" BorderThickness="0" Click="EditButton_Click"/>
                <Button Content="删除" Tag="delete_btn" Height="26" Width="60" Margin="5,0" Background="#E53935" Foreground="White" BorderThickness="0" Click="DeleteButton_Click"/>
                <Button Content="刷新" Tag="refresh_btn" Height="26" Width="60" Margin="5,0" Background="#607D8B" Foreground="White" BorderThickness="0" Click="RefreshButton_Click"/>
                <Button Content="关闭" Tag="close_btn" Height="26" Width="60" Margin="5,0" Background="#757575" Foreground="White" BorderThickness="0" Click="CloseButton_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="8,6">
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="关键字:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="KeywordFilterText" Width="180" VerticalContentAlignment="Center" Margin="0,0,12,0"
                         TextChanged="OnFilterChanged"/>

                <TextBlock Text="已接收:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="ReceivedFilterCombo" Width="100" Margin="0,0,12,0" SelectionChanged="OnFilterChanged"/>

                <TextBlock Text="已签收:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="AcceptedFilterCombo" Width="100" Margin="0,0,12,0" SelectionChanged="OnFilterChanged"/>

                <TextBlock Text="发放日期:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <DatePicker x:Name="DateFromPicker" Width="130" SelectedDateFormat="Short" Margin="0,0,4,0"
                            SelectedDateChanged="OnFilterChanged"/>
                <TextBlock Text="~" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <DatePicker x:Name="DateToPicker" Width="130" SelectedDateFormat="Short" Margin="0,0,12,0"
                            SelectedDateChanged="OnFilterChanged"/>

                <Button Content="清空筛选" Width="86" Click="ClearFilters_Click"/>
            </WrapPanel>
        </Border>

        <DataGrid Grid.Row="2" x:Name="RecordGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  GridLinesVisibility="Horizontal" BorderThickness="0" SelectionMode="Single" SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                <DataGridTextColumn Header="报告编号" Binding="{Binding ReportCode}" Width="120"/>
                <DataGridTextColumn Header="发放日期" Binding="{Binding DistributionDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridTextColumn Header="发放人" Binding="{Binding Distributor}" Width="90"/>
                <DataGridTextColumn Header="接收人" Binding="{Binding Recipient}" Width="90"/>
                <DataGridTextColumn Header="接收日期" Binding="{Binding ReceiveDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridTextColumn Header="签收人" Binding="{Binding Acceptor}" Width="90"/>
                <DataGridCheckBoxColumn Header="已接收" Binding="{Binding IsReceived}" Width="70"/>
                <DataGridTextColumn Header="签收日期" Binding="{Binding AcceptDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridCheckBoxColumn Header="已签收" Binding="{Binding IsAccepted}" Width="70"/>
                <DataGridTextColumn Header="备注" Binding="{Binding Remarks}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
