<Page x:Class="食品信息管理系统.Views.Pages.NutritionParamsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="营养参数">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                <Button Content="新增" Tag="add_btn" Height="26" Width="60" Margin="5,0" Background="#4CAF50" Foreground="White" BorderThickness="0" Click="AddButton_Click"/>
                <Button Content="编辑" Tag="edit_btn" Height="26" Width="60" Margin="5,0" Background="#2196F3" Foreground="White" BorderThickness="0" Click="EditButton_Click"/>
                <Button Content="删除" Tag="delete_btn" Height="26" Width="60" Margin="5,0" Background="#E53935" Foreground="White" BorderThickness="0" Click="DeleteButton_Click"/>
                <Button Content="刷新" Tag="refresh_btn" Height="26" Width="60" Margin="5,0" Background="#607D8B" Foreground="White" BorderThickness="0" Click="RefreshButton_Click"/>
                <Button Content="关闭" Tag="close_btn" Height="26" Width="60" Margin="5,0" Background="#757575" Foreground="White" BorderThickness="0" Click="CloseButton_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="8,6">
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="关键字:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="KeywordFilterText" Width="180" VerticalContentAlignment="Center" Margin="0,0,12,0"
                         TextChanged="OnFilterChanged"/>

                <TextBlock Text="营养素:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="NutrientFilterCombo" Width="140" IsEditable="True" IsTextSearchEnabled="True" Margin="0,0,12,0"
                          SelectionChanged="OnFilterChanged" LostFocus="OnFilterChanged"/>

                <CheckBox x:Name="DisabledOnlyCheck" Content="仅停用" Margin="0,0,12,0" VerticalAlignment="Center"
                          Checked="OnFilterChanged" Unchecked="OnFilterChanged"/>

                <Button Content="清空筛选" Width="86" Click="ClearFilters_Click"/>
            </WrapPanel>
        </Border>

        <DataGrid Grid.Row="2" x:Name="RecordGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  GridLinesVisibility="Horizontal" BorderThickness="0" SelectionMode="Single" SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="排序" Binding="{Binding SortOrder}" Width="60"/>
                <DataGridTextColumn Header="营养素" Binding="{Binding Nutrient}" Width="120"/>
                <DataGridTextColumn Header="单位" Binding="{Binding Unit}" Width="70"/>
                <DataGridTextColumn Header="四舍五入间隔" Binding="{Binding RoundingInterval}" Width="100"/>
                <DataGridTextColumn Header="零值阈值" Binding="{Binding ZeroThreshold}" Width="90"/>
                <DataGridTextColumn Header="能量值" Binding="{Binding EnergyValue}" Width="80"/>
                <DataGridTextColumn Header="下限误差" Binding="{Binding LowerError}" Width="90"/>
                <DataGridTextColumn Header="上限误差" Binding="{Binding UpperError}" Width="90"/>
                <DataGridTextColumn Header="NRV" Binding="{Binding Nrv}" Width="80"/>
                <DataGridCheckBoxColumn Header="核心" Binding="{Binding Core}" Width="60"/>
                <DataGridCheckBoxColumn Header="重金属" Binding="{Binding HeavyMetal}" Width="70"/>
                <DataGridCheckBoxColumn Header="运动营养" Binding="{Binding IsSportsNutrition}" Width="80"/>
                <DataGridTextColumn Header="日摄入范围" Binding="{Binding DailyUsageRange}" Width="120"/>
                <DataGridCheckBoxColumn Header="停用" Binding="{Binding Disabled}" Width="60"/>
                <DataGridTextColumn Header="参数键" Binding="{Binding ParamKey}" Width="120"/>
                <DataGridTextColumn Header="参数值" Binding="{Binding ParamValue}" Width="160"/>
                <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
