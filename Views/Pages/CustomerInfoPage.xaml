<Page x:Class="食品信息管理系统.Views.Pages.CustomerInfoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="客户信息">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                <Button Content="新增" Tag="add_btn" Height="26" Width="60" Margin="5,0" Background="#4CAF50" Foreground="White" BorderThickness="0" Click="AddButton_Click"/>
                <Button Content="编辑" Tag="edit_btn" Height="26" Width="60" Margin="5,0" Background="#2196F3" Foreground="White" BorderThickness="0" Click="EditButton_Click"/>
                <Button Content="删除" Tag="delete_btn" Height="26" Width="60" Margin="5,0" Background="#E53935" Foreground="White" BorderThickness="0" Click="DeleteButton_Click"/>
                <Button Content="刷新" Tag="refresh_btn" Height="26" Width="60" Margin="5,0" Background="#607D8B" Foreground="White" BorderThickness="0" Click="RefreshButton_Click"/>
                <Button Content="关闭" Tag="close_btn" Height="26" Width="60" Margin="5,0" Background="#757575" Foreground="White" BorderThickness="0" Click="CloseButton_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="8,6">
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="关键字:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="KeywordFilterText" Width="180" VerticalContentAlignment="Center" Margin="0,0,12,0"
                         TextChanged="OnFilterChanged"/>

                <TextBlock Text="来源:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="SourceFilterCombo" Width="120" IsEditable="True" IsTextSearchEnabled="True" Margin="0,0,12,0"
                          SelectionChanged="OnFilterChanged" LostFocus="OnFilterChanged"/>

                <TextBlock Text="类型:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="TypeFilterCombo" Width="120" IsEditable="True" IsTextSearchEnabled="True" Margin="0,0,12,0"
                          SelectionChanged="OnFilterChanged" LostFocus="OnFilterChanged"/>

                <CheckBox x:Name="DisabledOnlyCheck" Content="仅停用" Margin="0,0,12,0" VerticalAlignment="Center"
                          Checked="OnFilterChanged" Unchecked="OnFilterChanged"/>

                <Button Content="清空筛选" Width="86" Click="ClearFilters_Click"/>
            </WrapPanel>
        </Border>

        <DataGrid Grid.Row="2" x:Name="RecordGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  GridLinesVisibility="Horizontal" BorderThickness="0" SelectionMode="Single" SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="客户编号" Binding="{Binding CustomerId}" Width="110"/>
                <DataGridTextColumn Header="来源" Binding="{Binding Source}" Width="90"/>
                <DataGridTextColumn Header="客户名称" Binding="{Binding CustomerName}" Width="150"/>
                <DataGridTextColumn Header="客户类型" Binding="{Binding CustomerType}" Width="110"/>
                <DataGridTextColumn Header="许可证号" Binding="{Binding LicenseNo}" Width="120"/>
                <DataGridTextColumn Header="许可证有效期" Binding="{Binding LicenseValidity}" Width="110"/>
                <DataGridTextColumn Header="营业执照" Binding="{Binding BusinessLicense}" Width="120"/>
                <DataGridTextColumn Header="营业有效期" Binding="{Binding BusinessValidity}" Width="110"/>
                <DataGridTextColumn Header="联系地址" Binding="{Binding ContactAddress}" Width="180"/>
                <DataGridTextColumn Header="联系人" Binding="{Binding ContactPerson}" Width="90"/>
                <DataGridTextColumn Header="电话" Binding="{Binding ContactPhone}" Width="110"/>
                <DataGridCheckBoxColumn Header="停用" Binding="{Binding IsDisabled}" Width="70"/>
                <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
