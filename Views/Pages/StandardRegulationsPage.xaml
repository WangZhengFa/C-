<Page x:Class="食品信息管理系统.Views.Pages.StandardRegulationsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="标准规范">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                <Button Content="新增" Tag="add_btn" Height="26" Width="60" Margin="5,0" Background="#4CAF50" Foreground="White" BorderThickness="0" Click="AddButton_Click"/>
                <Button Content="编辑" Tag="edit_btn" Height="26" Width="60" Margin="5,0" Background="#2196F3" Foreground="White" BorderThickness="0" Click="EditButton_Click"/>
                <Button Content="删除" Tag="delete_btn" Height="26" Width="60" Margin="5,0" Background="#E53935" Foreground="White" BorderThickness="0" Click="DeleteButton_Click"/>
                <Button Content="刷新" Tag="refresh_btn" Height="26" Width="60" Margin="5,0" Background="#607D8B" Foreground="White" BorderThickness="0" Click="RefreshButton_Click"/>
                <Button Content="关闭" Tag="close_btn" Height="26" Width="60" Margin="5,0" Background="#757575" Foreground="White" BorderThickness="0" Click="CloseButton_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="8,6">
            <WrapPanel VerticalAlignment="Center">
                <TextBlock Text="关键字:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox x:Name="KeywordFilterText" Width="180" VerticalContentAlignment="Center" Margin="0,0,12,0"
                         TextChanged="OnFilterChanged"/>

                <TextBlock Text="节点编码:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="NodeCodeFilterCombo" Width="130" IsEditable="True" IsTextSearchEnabled="True" Margin="0,0,12,0"
                          SelectionChanged="OnFilterChanged" LostFocus="OnFilterChanged"/>

                <TextBlock Text="分类:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox x:Name="CategoryFilterCombo" Width="120" IsEditable="True" IsTextSearchEnabled="True" Margin="0,0,12,0"
                          SelectionChanged="OnFilterChanged" LostFocus="OnFilterChanged"/>

                <CheckBox x:Name="EnabledOnlyCheck" Content="仅启用" Margin="0,0,12,0" VerticalAlignment="Center"
                          Checked="OnFilterChanged" Unchecked="OnFilterChanged"/>

                <Button Content="清空筛选" Width="86" Click="ClearFilters_Click"/>
            </WrapPanel>
        </Border>

        <DataGrid Grid.Row="2" x:Name="RecordGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  GridLinesVisibility="Horizontal" BorderThickness="0" SelectionMode="Single" SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="标准编号" Binding="{Binding StandardId}" Width="120"/>
                <DataGridTextColumn Header="节点编码" Binding="{Binding NodeCode}" Width="120"/>
                <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="100"/>
                <DataGridTextColumn Header="系列" Binding="{Binding Series}" Width="100"/>
                <DataGridTextColumn Header="标准名称" Binding="{Binding StandardName}" Width="160"/>
                <DataGridTextColumn Header="标准代号" Binding="{Binding StandardCode}" Width="120"/>
                <DataGridTextColumn Header="发布部门" Binding="{Binding PublishDept}" Width="140"/>
                <DataGridTextColumn Header="年份" Binding="{Binding PublishYear}" Width="80"/>
                <DataGridCheckBoxColumn Header="HACCP" Binding="{Binding AppliesToHaccp}" Width="70"/>
                <DataGridTextColumn Header="发布日期" Binding="{Binding PublishDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridTextColumn Header="实施日期" Binding="{Binding ImplementDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridTextColumn Header="修订日期" Binding="{Binding RevisionDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridTextColumn Header="生效日期" Binding="{Binding EffectiveDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridCheckBoxColumn Header="失效" Binding="{Binding IsInvalid}" Width="70"/>
                <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsEnabled}" Width="70"/>
                <DataGridTextColumn Header="备注" Binding="{Binding Remark}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
