<Window x:Class="FoodEnterpriseIMS.MainAppWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FoodEnterpriseIMS"
        xmlns:widgets="clr-namespace:FoodEnterpriseIMS.Widgets"
        mc:Ignorable="d"
        Title="食品企业信息管理系统" Height="800" Width="1280"
        MinHeight="600" MinWidth="960"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Window.Resources>
        <!-- 样式定义 -->
        <Style x:Key="SectionTitleLabel" TargetType="Label">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style x:Key="MutedLabel" TargetType="Label">
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <!-- 状态栏 -->
        <StatusBar DockPanel.Dock="Bottom" HorizontalAlignment="Stretch">
            <StatusBarItem HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal" Margin="5,0">
                    <Label x:Name="LblDateTime" Style="{StaticResource MutedLabel}"/>
                    <Label Style="{StaticResource MutedLabel}"> | </Label>
                    <Label x:Name="LblRuntimeMode" Style="{StaticResource MutedLabel}" Content="网络版"/>
                    <Label Style="{StaticResource MutedLabel}"> | </Label>
                    <Label x:Name="LblUser" Style="{StaticResource MutedLabel}"/>
                    <Label Style="{StaticResource MutedLabel}"> | </Label>
                    <Label x:Name="LblVersion" Style="{StaticResource MutedLabel}"/>
                    <Label Style="{StaticResource MutedLabel}"> | </Label>
                    <Label x:Name="LblDbStatus" Style="{StaticResource MutedLabel}" Content="DB: 已连接"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>

        <!-- 主内容区 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20"/> <!-- 切换按钮列 -->
                <ColumnDefinition Width="120" x:Name="ColTreePanel"/> <!-- 树面板列 -->
                <ColumnDefinition Width="*"/> <!-- 内容区域列 -->
            </Grid.ColumnDefinitions>

            <!-- 侧边栏切换按钮 -->
            <Border Grid.Column="0" Background="Transparent" MouseLeftButtonUp="ToggleTreePanel_Click">
                <Label x:Name="LblToggleIcon" Content="&lt;&lt;" HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontSize="14" FontWeight="Bold" Foreground="#666666"/>
            </Border>

            <!-- 树菜单面板 -->
            <Border Grid.Column="1" BorderThickness="1" BorderBrush="#999999" CornerRadius="4">
                <widgets:MenuTreeView x:Name="TreeMenu" Header="系统菜单" 
                                     ItemClicked="TreeMenu_ItemClicked"
                                     ItemDoubleClicked="TreeMenu_ItemDoubleClicked"/>
            </Border>

            <!-- 内容区域 -->
            <Border Grid.Column="2" BorderThickness="1" BorderBrush="#666666" CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="26"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- 页面标题（透明背景，文字直接在内容背景上） -->
                    <Label Grid.Row="0" x:Name="LblPageTitle" Style="{StaticResource SectionTitleLabel}"
                           Margin="6,0,6,0" HorizontalAlignment="Left" VerticalAlignment="Center"
                           Content=""/>
                    <!-- 内容容器 -->
                    <TabControl Grid.Row="1" x:Name="ContentArea" BorderThickness="0" Background="Transparent">
                        <TabControl.ItemContainerStyle>
                            <Style TargetType="TabItem">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </Style>
                        </TabControl.ItemContainerStyle>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>