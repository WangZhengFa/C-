<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:FoodEnterpriseIMS.Themes">

    <!-- 深色主题样式 -->
    <ResourceDictionary x:Key="DarkTheme">
        <!-- 颜色资源 -->
        <SolidColorBrush x:Key="DarkBackground" Color="#121212"/>
        <SolidColorBrush x:Key="DarkForeground" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="DarkControlBackground" Color="#222222"/>
        <SolidColorBrush x:Key="DarkBorder" Color="#444444"/>
        <SolidColorBrush x:Key="DarkPrimaryButton" Color="#4CAF50"/>
        <SolidColorBrush x:Key="DarkSecondaryButton" Color="#1976d2"/>
        <SolidColorBrush x:Key="DarkDangerButton" Color="#F44336"/>
        <SolidColorBrush x:Key="DarkSuccessButton" Color="#2e7d32"/>
        <SolidColorBrush x:Key="DarkInfoButton" Color="#0288d1"/>
        <SolidColorBrush x:Key="DarkWarningButton" Color="#f9a825"/>
        <SolidColorBrush x:Key="DarkErrorButton" Color="#c62828"/>
        <SolidColorBrush x:Key="DarkSelectedItem" Color="#005BBB"/>
        <SolidColorBrush x:Key="DarkHoverItem" Color="#2F3B4A"/>
        <!-- 全局控件样式 -->
        <Style TargetType="Control">
            <Setter Property="Background" Value="{StaticResource DarkBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource DarkForeground}"/>
            <Setter Property="FontFamily" Value="{x:Static local:ThemeConstants+Fonts.DefaultFontFamily}"/>
            <Setter Property="FontSize" Value="{x:Static local:ThemeConstants+Fonts.DefaultFontSize}"/>
        </Style>

        <!-- 文本控件（Label/TextBox/ComboBox等） -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource DarkForeground}"/>
            <Setter Property="MinHeight" Value="{x:Static local:ThemeConstants+Sizes.MinControlHeight}"/>
            <Setter Property="Margin" Value="1"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource DarkControlBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource DarkForeground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight" Value="{x:Static local:ThemeConstants+Sizes.MinControlHeight}"/>
            <Setter Property="Padding" Value="1 4"/>
            <Setter Property="Margin" Value="1"/>
        </Style>

        <!-- 按钮样式 -->
        <Style TargetType="Button" x:Key="DefaultButtonStyle">
            <Setter Property="Background" Value="{StaticResource DarkPrimaryButton}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="FontSize" Value="{x:Static local:ThemeConstants+Fonts.ButtonFontSize}"/>
            <Setter Property="MinHeight" Value="{x:Static local:ThemeConstants+Sizes.MinControlHeight}"/>
            <Setter Property="Margin" Value="1"/>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButtonStyle" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Background" Value="{StaticResource DarkSecondaryButton}"/>
        </Style>

        <Style TargetType="Button" x:Key="DangerButtonStyle" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Background" Value="{StaticResource DarkDangerButton}"/>
        </Style>

        <Style TargetType="Button" x:Key="TableButtonStyle" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Background" Value="{StaticResource DarkInfoButton}"/>
            <Setter Property="Padding" Value="0 6"/>
            <Setter Property="FontSize" Value="{x:Static local:ThemeConstants+Fonts.TableButtonFontSize}"/>
            <Setter Property="MinHeight" Value="{x:Static local:ThemeConstants+Sizes.TableButtonHeight}"/>
            <Setter Property="MaxHeight" Value="{x:Static local:ThemeConstants+Sizes.TableButtonHeight}"/>
        </Style>

        <!-- 树控件/列表控件 -->
        <Style TargetType="TreeView">
            <Setter Property="Background" Value="{StaticResource DarkControlBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource DarkForeground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DarkBorder}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeView">
                        <Border BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}">
                            <ScrollViewer CanContentScroll="True" Focusable="False">
                                <ItemsPresenter Margin="{TemplateBinding Padding}"/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="MinHeight" Value="{x:Static local:ThemeConstants+Sizes.TreeRowHeight}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="19"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 连接线 -->
                            <Rectangle x:Name="HorLn"
                                       Grid.Column="0" Grid.Row="0"
                                       Height="1" Stroke="#888888"
                                       SnapsToDevicePixels="True"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Center"
                                       Margin="9,1,1,0"/>
                            
                            <Rectangle x:Name="VerLn"
                                       Grid.Column="0" Grid.Row="0"
                                       Width="1" Stroke="#888888"
                                       SnapsToDevicePixels="True"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Stretch"
                                       Margin="0,0,1,0"/>

                            <!-- +/- 展开折叠按钮 -->
                            <ToggleButton x:Name="Expander"
                                          Grid.Column="0" Grid.Row="0"
                                          Width="16" Height="16"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Width="16" Height="16"
                                                Background="White"
                                                BorderBrush="#888888"
                                                BorderThickness="1">
                                            <Grid>
                                                <!-- 横线 -->
                                                <Rectangle Width="8" Height="1" Fill="#000000"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <!-- 竖线（仅在折叠时显示） -->
                                                <Rectangle x:Name="PlusLine"
                                                           Width="1" Height="8" Fill="#000000"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="PlusLine" Property="Visibility" Value="Collapsed"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <!-- 内容区域 -->
                            <Border x:Name="Bd"
                                    Grid.Column="1" Grid.Row="0"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="4,6,8,6"
                                    SnapsToDevicePixels="true">
                                <ContentPresenter x:Name="PART_Header"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Border>

                            <!-- 子项容器 -->
                            <ItemsPresenter x:Name="ItemsHost"
                                            Grid.ColumnSpan="2"
                                            Grid.Row="1"
                                            Margin="19,0,0,0"
                                            Visibility="Collapsed"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <!-- 展开状态显示子项 -->
                            <Trigger Property="IsExpanded" Value="true">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                            </Trigger>

                            <!-- 没有子项时隐藏展开按钮和连接线 -->
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="HorLn" Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="VerLn" Property="Visibility" Value="Hidden"/>
                            </Trigger>

                            <!-- 选中状态 -->
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource DarkSelectedItem}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>

                            <!-- 鼠标悬停 -->
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource DarkHoverItem}"/>
                                <Setter Property="Foreground" Value="{StaticResource DarkForeground}"/>
                            </Trigger>

                            <!-- 禁用状态 -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="true"/>
                                    <Condition Property="IsSelectionActive" Value="false"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#3F3F3F"/>
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 复选框 -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{x:Static local:ThemeConstants+DarkColors.Foreground}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="{x:Static local:ThemeConstants+Sizes.IndicatorSize}" 
                              Height="{x:Static local:ThemeConstants+Sizes.IndicatorSize}">
                            <Border x:Name="CheckBorder" 
                                    BorderBrush="#9BB8D3" 
                                    BorderThickness="1" 
                                    Background="#3C3F41"
                                    CornerRadius="3"/>
                            <Path x:Name="CheckMark" 
                                  Data="M0,5 5,10 10,0" 
                                  Stroke="White" 
                                  StrokeThickness="2" 
                                  Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="#64b5f6"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#64b5f6"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#555555"/>
                                <Setter TargetName="CheckBorder" Property="Background" Value="#2F2F2F"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#2196f3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ResourceDictionary>

    <!-- 浅色主题样式 -->
    <ResourceDictionary x:Key="LightTheme">
        <!-- 颜色资源 -->
        <SolidColorBrush x:Key="LightBackground" Color="#F2F2F2"/>
        <SolidColorBrush x:Key="LightForeground" Color="#222222"/>
        <SolidColorBrush x:Key="LightControlBackground" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="LightBorder" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="LightPrimaryButton" Color="#4CAF50"/>
        <SolidColorBrush x:Key="LightSecondaryButton" Color="#1976d2"/>
        <SolidColorBrush x:Key="LightDangerButton" Color="#F44336"/>
        <SolidColorBrush x:Key="LightSuccessButton" Color="#2e7d32"/>
        <SolidColorBrush x:Key="LightInfoButton" Color="#0288d1"/>
        <SolidColorBrush x:Key="LightWarningButton" Color="#f9a825"/>
        <SolidColorBrush x:Key="LightErrorButton" Color="#c62828"/>
        <SolidColorBrush x:Key="LightSelectedItem" Color="#005BBB"/>
        <SolidColorBrush x:Key="LightHoverItem" Color="#e5f0ff"/>
        <!-- 全局控件样式 -->
        <Style TargetType="Control">
            <Setter Property="Background" Value="{StaticResource LightBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource LightForeground}"/>
            <Setter Property="FontFamily" Value="{x:Static local:ThemeConstants+Fonts.DefaultFontFamily}"/>
            <Setter Property="FontSize" Value="{x:Static local:ThemeConstants+Fonts.DefaultFontSize}"/>
        </Style>

        <!-- 文本控件 -->
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource LightForeground}"/>
            <Setter Property="MinHeight" Value="{x:Static local:ThemeConstants+Sizes.MinControlHeight}"/>
            <Setter Property="Margin" Value="1"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource LightControlBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource LightForeground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinHeight" Value="{x:Static local:ThemeConstants+Sizes.MinControlHeight}"/>
            <Setter Property="Padding" Value="1 4"/>
            <Setter Property="Margin" Value="1"/>
        </Style>

        <!-- 按钮样式 -->
        <Style TargetType="Button" x:Key="DefaultButtonStyle">
            <Setter Property="Background" Value="{StaticResource LightPrimaryButton}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0,10"/>
            <Setter Property="FontSize" Value="{x:Static local:ThemeConstants+Fonts.ButtonFontSize}"/>
            <Setter Property="MinHeight" Value="{x:Static local:ThemeConstants+Sizes.MinControlHeight}"/>
            <Setter Property="Margin" Value="1"/>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButtonStyle" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Background" Value="{StaticResource LightSecondaryButton}"/>
        </Style>

        <Style TargetType="Button" x:Key="DangerButtonStyle" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Background" Value="{StaticResource LightDangerButton}"/>
        </Style>

        <Style TargetType="Button" x:Key="TableButtonStyle" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Background" Value="{StaticResource LightInfoButton}"/>
            <Setter Property="Padding" Value="0 6"/>
            <Setter Property="FontSize" Value="{x:Static local:ThemeConstants+Fonts.TableButtonFontSize}"/>
            <Setter Property="MinHeight" Value="{x:Static local:ThemeConstants+Sizes.TableButtonHeight}"/>
            <Setter Property="MaxHeight" Value="{x:Static local:ThemeConstants+Sizes.TableButtonHeight}"/>
        </Style>

        <!-- 树控件 -->
        <Style TargetType="TreeView">
            <Setter Property="Background" Value="{StaticResource LightControlBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource LightForeground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LightBorder}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeView">
                        <Border BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Background="{TemplateBinding Background}">
                            <ScrollViewer CanContentScroll="True" Focusable="False">
                                <ItemsPresenter Margin="{TemplateBinding Padding}"/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="MinHeight" Value="{x:Static local:ThemeConstants+Sizes.TreeRowHeight}"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="19"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 连接线 -->
                            <Rectangle x:Name="HorLn"
                                       Grid.Column="0" Grid.Row="0"
                                       Height="1" Stroke="#888888"
                                       SnapsToDevicePixels="True"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Center"
                                       Margin="9,1,1,0"/>
                            
                            <Rectangle x:Name="VerLn"
                                       Grid.Column="0" Grid.Row="0"
                                       Width="1" Stroke="#888888"
                                       SnapsToDevicePixels="True"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Stretch"
                                       Margin="0,0,1,0"/>

                            <!-- +/- 展开折叠按钮 -->
                            <ToggleButton x:Name="Expander"
                                          Grid.Column="0" Grid.Row="0"
                                          Width="16" Height="16"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Width="16" Height="16"
                                                Background="White"
                                                BorderBrush="#888888"
                                                BorderThickness="1">
                                            <Grid>
                                                <!-- 横线 -->
                                                <Rectangle Width="8" Height="1" Fill="#000000"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                <!-- 竖线（仅在折叠时显示） -->
                                                <Rectangle x:Name="PlusLine"
                                                           Width="1" Height="8" Fill="#000000"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="PlusLine" Property="Visibility" Value="Collapsed"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <!-- 内容区域 -->
                            <Border x:Name="Bd"
                                    Grid.Column="1" Grid.Row="0"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="4,6,8,6"
                                    SnapsToDevicePixels="true">
                                <ContentPresenter x:Name="PART_Header"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Border>

                            <!-- 子项容器 -->
                            <ItemsPresenter x:Name="ItemsHost"
                                            Grid.ColumnSpan="2"
                                            Grid.Row="1"
                                            Margin="19,0,0,0"
                                            Visibility="Collapsed"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <!-- 展开状态显示子项 -->
                            <Trigger Property="IsExpanded" Value="true">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                            </Trigger>

                            <!-- 没有子项时隐藏展开按钮和连接线 -->
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="HorLn" Property="Visibility" Value="Hidden"/>
                                <Setter TargetName="VerLn" Property="Visibility" Value="Hidden"/>
                            </Trigger>

                            <!-- 选中状态 -->
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource LightSelectedItem}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>

                            <!-- 鼠标悬停 -->
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource LightHoverItem}"/>
                                <Setter Property="Foreground" Value="{StaticResource LightForeground}"/>
                            </Trigger>

                            <!-- 禁用状态 -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="true"/>
                                    <Condition Property="IsSelectionActive" Value="false"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="#E0E0E0"/>
                                <Setter Property="Foreground" Value="#666666"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 复选框 -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{x:Static local:ThemeConstants+LightColors.Foreground}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="{x:Static local:ThemeConstants+Sizes.LightIndicatorSize}" 
                              Height="{x:Static local:ThemeConstants+Sizes.LightIndicatorSize}">
                            <Border x:Name="CheckBorder" 
                                    BorderBrush="#9E9E9E" 
                                    BorderThickness="1" 
                                    Background="White"
                                    CornerRadius="2"/>
                            <Path x:Name="CheckMark" 
                                  Data="M0,5 5,10 10,0" 
                                  Stroke="White" 
                                  StrokeThickness="2" 
                                  Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckBorder" Property="Background" Value="#1976d2"/>
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#1976d2"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#CFCFCF"/>
                                <Setter TargetName="CheckBorder" Property="Background" Value="#F2F2F2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckBorder" Property="BorderBrush" Value="#1565C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </ResourceDictionary>
</ResourceDictionary>